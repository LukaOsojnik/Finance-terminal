<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — BBT</title>
    @* Apply the saved theme on <html> BEFORE first paint so light-mode users never see a dark flash. *@
    <script>
        (function () {
            try {
                if (localStorage.getItem('bbt-theme') === 'light')
                    document.documentElement.setAttribute('data-theme', 'light');
            } catch (e) { }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/simple_bloomberg_terminal.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/dtpicker.css" asp-append-version="true"/>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
@* Auth state for the client-side sign-in switch (site.js): data-auth = logged in at all; data-priv =
   has the Admin/Manager role the AJAX features require. The click-guard reads these to prompt BEFORE a
   protected button runs any of its own UI. *@
<body data-auth="@(User?.Identity?.IsAuthenticated == true ? "1" : "0")"
      data-priv="@(User is { } u && (u.IsInRole("Admin") || u.IsInRole("Manager")) ? "1" : "0")">
<header id="main-nav" data-turbo-permanent>
    <nav class="navbar navbar-expand-sm">
        <div class="container-fluid" style="max-width:1200px; margin:0 auto; padding:0 1rem;">
            <a class="terminal-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-bracket">[</span>BBT<span class="brand-bracket">]</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav" style="gap:0.25rem;">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Terminal</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Countries</a>
                        <ul class="dropdown-menu terminal-dropdown">
                            <li><a class="dropdown-item" asp-controller="Countries" asp-action="Index">Countries</a></li>
                            <li><a class="dropdown-item" asp-controller="TradeBlocs" asp-action="Index">Trade Blocs</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Markets</a>
                        <ul class="dropdown-menu terminal-dropdown">
                            <li><h6 class="dropdown-header">Stocks</h6></li>
                            <li><a class="dropdown-item" asp-controller="Companies" asp-action="Index">Companies</a></li>
                            <li><a class="dropdown-item" asp-controller="Indices" asp-action="Index">Indices</a></li>
                        </ul>
                    </li>
                    @if (User is { } reviewer && (reviewer.IsInRole("Admin") || reviewer.IsInRole("Manager")))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Contributions" asp-action="Index">Review</a>
                        </li>
                    }
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">More</a>
                        <ul class="dropdown-menu terminal-dropdown">
                            <li><a class="dropdown-item" asp-controller="Events" asp-action="Index">Events</a></li>
                            <li><a class="dropdown-item" asp-controller="Graph" asp-action="Index">Graph</a></li>
                            <li><a class="dropdown-item" asp-area="" asp-route="ImpactIndex">Impact</a></li>
                            <li><a class="dropdown-item" asp-controller="Extraction" asp-action="Index">Extraction</a></li>
                        </ul>
                    </li>
                </ul>
                <partial name="_LoginPartial"/>
                <button id="themeToggle" class="theme-toggle" type="button"
                        aria-label="Toggle light / dark theme" title="Toggle theme">
                    @* moon shows in dark mode, sun in light mode (swapped via CSS) *@
                    <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                    <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="4"/>
                        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
                    </svg>
                </button>
            </div>
        </div>
    </nav>
</header>

<div id="ticker" data-turbo-permanent aria-label="Live data ticker">
    <div class="ticker-tag">LIVE</div>
    <div class="ticker-viewport">
        <div class="ticker-track" id="ticker-track"></div>
    </div>
</div>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer id="main-footer" data-turbo-permanent class="terminal-footer">
    <div class="container">
        <div class="footer-inner">
            <div>
                &copy; 2026 &mdash; <span style="color:var(--accent);">Bloomberg Terminal</span>
                &nbsp;&middot;&nbsp;
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
            <div class="footer-status">
                <span class="footer-dot"></span>
                FEED ACTIVE
            </div>
        </div>
    </div>
</footer>

<!-- Background-scan notifications: rebuilt from the server on every page (no SPA shell), so a
     scan started on the extraction page survives navigation and pings here when it finishes. -->
<div id="scanNotify" class="scan-notify" hidden>
    <button id="scanNotifyChip" class="scan-notify-chip" type="button">
        <span class="scan-notify-dot"></span>
        <span>SCANS</span>
        <span id="scanNotifyBadge" class="scan-notify-badge">0</span>
    </button>
    <div id="scanNotifyPanel" class="scan-notify-panel" hidden>
        <div id="scanNotifyWGrip" class="scan-notify-wgrip" hidden title="Drag to resize width"></div>
        <div class="scan-notify-head">
            <span>FILING SCANS</span>
            <button id="scanNotifyClose" class="scan-notify-x" type="button" aria-label="Close">&times;</button>
        </div>
        <!-- Filing document + its TOC: shown only when the open chat's scan ran on a filing. Pinned
             static on the left while the existing list+chat widget resizes on the right. -->
        <div id="scanNotifyDoc" class="scan-notify-doc" hidden>
            <div id="scanNotifyDocPane" class="scan-notify-doc-pane"></div>
        </div>
        <nav id="scanNotifyToc" class="scan-notify-toc" hidden></nav>
        <div id="scanNotifyList" class="scan-notify-list"></div>
        <div id="scanNotifyChat" class="scan-notify-chat" hidden>
            <button id="scanNotifyBack" class="scan-notify-back" type="button">&larr; All scans</button>
            <div id="scanNotifyChatHead" class="scan-notify-chat-head"></div>
            <div id="scanNotifyLog" class="scan-notify-log"></div>
            <div id="scanNotifySavesGrip" class="scan-notify-grip" hidden title="Drag to resize"></div>
            <div id="scanNotifySaves" class="scan-notify-saves" hidden></div>
            <div class="scan-notify-compose">
                <textarea id="scanNotifyInput" class="scan-notify-input" rows="2"
                          placeholder="Ask about this filing…"></textarea>
                <button id="scanNotifySend" class="scan-notify-send" type="button">Send</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit one proposed save before committing it — fields match the extraction form per node. -->
<div id="scanEditModal" class="scan-edit-overlay" hidden>
    <div class="scan-edit-box">
        <div class="scan-edit-head">
            <span id="scanEditTitle">Edit object</span>
            <button id="scanEditClose" class="scan-notify-x" type="button" aria-label="Close">&times;</button>
        </div>
        <div id="scanEditBody" class="scan-edit-body"></div>
        <div class="scan-edit-foot">
            <button id="scanEditCancel" class="scan-edit-btn-ghost" type="button">Cancel</button>
            <button id="scanEditApply" class="scan-notify-save-btn" type="button">Apply</button>
        </div>
    </div>
</div>

<!-- Under-the-hood inspector: the exact prompt one scan agent saw + its raw reply. -->
<div id="scanChunkModal" class="scan-edit-overlay" hidden>
    <div class="scan-edit-box scan-chunk-box">
        <div class="scan-edit-head">
            <span id="scanChunkTitle">Agent call</span>
            <button id="scanChunkClose" class="scan-notify-x" type="button" aria-label="Close">&times;</button>
        </div>
        <div class="scan-chunk-inspect">
            <div class="scan-chunk-pane">
                <div class="scan-chunk-pane-head">Prompt sent to AI</div>
                <pre id="scanChunkPrompt" class="scan-chunk-pre"></pre>
            </div>
            <div class="scan-chunk-pane">
                <div class="scan-chunk-pane-head">AI response</div>
                <pre id="scanChunkResponse" class="scan-chunk-pre"></pre>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/dtpicker.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
