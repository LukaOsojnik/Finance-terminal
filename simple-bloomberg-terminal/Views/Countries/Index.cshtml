@model IEnumerable<simple_bloomberg_terminal.Models.ViewModels.CountryRowViewModel>
@{
    ViewData["Title"] = "Countries";
}

<div class="page-header">
    <h2><span class="page-header-accent">//</span> Countries</h2>
    <div class="page-subtitle">SOVEREIGN DATA — GDP · POPULATION · RISK RATINGS</div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex" style="margin-bottom:1rem; gap:0.75rem; align-items:center;">
    <input type="text" class="form-control search-input" placeholder="Search code / name / region..." data-search-url="@Url.Action("Search")" style="max-width:420px;"/>
    <a asp-action="Create" class="btn btn-primary">+ NEW</a>
</div>

<table class="terminal-table">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Region</th>
            <th>Currency</th>
            <th style="text-align:right;">GDP (USD)</th>
            <th style="text-align:right;">Population</th>
            <th style="text-align:right;">Risk</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="table-body">
        @await Html.PartialAsync("_TableBody", Model)
    </tbody>
</table>
