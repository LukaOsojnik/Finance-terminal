@model simple_bloomberg_terminal.Models.ViewModels.ExtractionIndexViewModel
@{ ViewData["Title"] = "Extraction"; }

<div class="page-header">
    <h2><span class="page-header-accent">//</span> Extraction — <span id="nodeTitle">Revenue</span></h2>
    <div class="page-subtitle">Bind cells to EDGAR proof text · pick the node, select in the right pane, freeze with “Use as reference”</div>
</div>

@Html.AntiForgeryToken()

<div class="extraction-split" id="extractionSplit">
    <!-- LEFT: source cells bound to a RevenueSource row -->
    <div class="extraction-pane" id="leftPane">
        <div class="cell-row">
            <label class="ext-field-label">Node</label>
            <select id="nodeSelect" asp-items="ViewBag.Nodes" class="ext-select"></select>
        </div>
        <div class="cell-row">
            <label class="ext-field-label">Company</label>
            @await Html.PartialAsync("_AutocompletePicker", new AutocompletePickerModel {
                FieldName = "companyId",
                SelectedId = Model.CompanyId,
                SelectedLabel = Model.CompanyLabel ?? "",
                LookupUrl = Url.Action("Lookup", "Companies"),
                Required = false,
                Placeholder = "Type company name..."
            })
            <button type="button" id="loadBtn" class="ext-btn ext-btn-secondary ext-btn-load">LOAD EDGAR ROWS</button>
            <button type="button" id="reviewBtn" class="ext-btn ext-btn-secondary ext-btn-load">AI REVIEW</button>
            <div id="loadStatus" class="ext-status"></div>
        </div>

        <!-- Mode B: chat grounded on the open filing. AI surfaces sources & proposes saves. -->
        <div id="aiChat" class="ai-chat" hidden>
            <div class="ai-chat-head">
                <span>AI Chat <span id="aiChatCtx" class="ai-chat-ctx"></span></span>
                <button type="button" class="ext-btn ext-btn-ghost ai-chat-close" id="aiChatClose">✕</button>
            </div>
            <!-- Auto-scan triage report: every heading offered, with the AI's picks marked. -->
            <div id="scanReport" class="scan-report" hidden></div>
            <div id="aiChatLog" class="ai-chat-log"></div>
            <!-- Proposed saves parsed from the reply; click a card to fill the cells above. -->
            <div id="aiSaveList" class="ai-suggest-list"></div>
            <div class="ai-chat-input">
                <textarea id="aiChatText" rows="2" placeholder="Ask about this filing… (Enter to send, Shift+Enter for newline)"></textarea>
                <button type="button" id="aiChatSend" class="ext-btn ext-btn-primary">Send</button>
            </div>
        </div>

        <div class="extraction-pane-head">
            <span class="extraction-pane-title">Source Row</span>
            <select id="rowPicker" class="ext-select">
                <option value="">— new row —</option>
            </select>
        </div>

        <div class="cell-row">
            <label class="ext-field-label" id="classLabel">Classification</label>
            <select id="f_sourceType" asp-items="ViewBag.SourceTypes" class="form-control"></select>
            <div class="ref-info" data-info="CLASSIFICATION"></div>
        </div>
        <div class="cell-row">
            <label class="ext-field-label">Name</label>
            <input id="f_name" class="form-control"/>
            <div class="ref-info" data-info="NAME"></div>
        </div>
        <div class="cell-row" id="valueRow">
            <label class="ext-field-label">Value</label>
            <input id="f_value" class="form-control" type="number" step="any"/>
            <div class="ref-info" data-info="VALUE"></div>
        </div>
        <div class="cell-row" id="pctRow">
            <label class="ext-field-label">% (0–100)</label>
            <input id="f_percentage" class="form-control" type="number" step="0.1"/>
            <div class="ref-info" data-info="PERCENTAGE"></div>
        </div>
        <div class="cell-row" id="counterpartyRow">
            <label class="ext-field-label">Counterparty</label>
            @await Html.PartialAsync("_AutocompletePicker", new AutocompletePickerModel {
                FieldName = "relatedCompanyId",
                SelectedId = Model.RelatedCompanyId,
                SelectedLabel = Model.RelatedCompanyLabel ?? "",
                LookupUrl = Url.Action("Lookup", "Companies"),
                Required = false,
                Placeholder = "Type company name (optional)..."
            })
            <div class="ref-info" data-info="RELATED_COMPANY"></div>
        </div>
        <!-- RISK node only: free-text note describing the risk. -->
        <div class="cell-row" id="noteRow" hidden>
            <label class="ext-field-label">Note</label>
            <textarea id="f_note" class="form-control" rows="3" placeholder="Short description of the risk..."></textarea>
            <div class="ref-info" data-info="NOTE"></div>
        </div>

        <!-- The one save: writes the row + every field that carries proof, in a single request. -->
        <div class="cell-row ext-save-row">
            <button type="button" id="saveBtn" class="ext-btn ext-btn-primary ext-btn-save">SAVE ROW</button>
            <div id="saveStatus" class="ext-status"></div>
        </div>
    </div>

    <!-- Drag to widen the filing/EDGAR pane -->
    <div class="extraction-gutter" id="extGutter" title="Drag to resize"><span></span></div>

    <!-- RIGHT: the actual EDGAR response; select text here to back a cell -->
    <div class="extraction-pane" id="rightPane">
        <div class="extraction-pane-head">
            <span class="extraction-pane-title">EDGAR — select proof text</span>
            <div class="extraction-pane-actions">
                <button type="button" id="factsBtn" class="ext-btn ext-btn-secondary">Company Facts</button>
                <button type="button" id="filingsBtn" class="ext-btn ext-btn-secondary">Filings</button>
                <button type="button" id="autoScanBtn" class="ext-btn ext-btn-ref">Auto-Scan</button>
                <button type="button" id="aiChatBtn" class="ext-btn ext-btn-ref">AI Chat</button>
            </div>
        </div>
        <div id="endpointLabel" class="ext-endpoint"></div>
        <pre id="response" class="extraction-json">Load a company, then open Company Facts or a filing.</pre>
        <div class="doc-shell">
            <div id="responseHtml" class="extraction-doc" hidden></div>
            <nav id="docToc" class="doc-toc" hidden></nav>
        </div>
    </div>
</div>

<!-- Wide filings browser: escapes the 1200px container so many filings show at once. -->
<div id="filingsModal" class="ext-modal" hidden>
    <div class="ext-modal-backdrop" data-close></div>
    <div class="ext-modal-panel">
        <div class="ext-modal-head">
            <div class="ext-modal-titlewrap">
                <span class="ext-modal-title">EDGAR Filings</span>
                <span id="filingsCount" class="ext-modal-count"></span>
            </div>
            <input id="filingsFilter" class="form-control ext-modal-filter" placeholder="Filter form / date / description..."/>
            <button type="button" class="ext-btn ext-btn-ghost" data-close>✕ CLOSE</button>
        </div>
        <div id="filingsGrid" class="ext-filings-grid"></div>
        <div id="filingsEmpty" class="ext-modal-empty" hidden>No filings match.</div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script type="application/json" id="nodeConfig">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
        initial = Model.Node.ToString(),
        classes = ViewBag.ClassOptions
    }))
</script>
@if (Model.RevenueSourceId is { } prefillId)
{
    <script type="application/json" id="prefillData">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            id = prefillId,
            sourceType = Model.SourceType?.ToString(),
            name = Model.Name,
            value = Model.Value,
            percentage = Model.Percentage
        }))
    </script>
}
<style>
    /* ── Company / load ── */
    .ext-btn-load { display: block; margin-top: .4rem; }
    /* The single commit action — bigger, sits under the cells. */
    .ext-save-row { margin-top: 1.1rem; padding-top: 1rem; border-top: 1px solid var(--border-subtle); }
    .ext-btn-save { width: 100%; padding: .7rem; font-size: .82rem; letter-spacing: .14em; }
    .ext-btn-save:hover { box-shadow: var(--accent-glow); }
    #saveStatus { margin-top: .55rem; }
    .ext-field-label {
        display: block; font-family: var(--font-display); font-size: .65rem; font-weight: 600;
        letter-spacing: .16em; text-transform: uppercase; color: var(--muted); margin-bottom: .35rem;
    }
    .ext-status { font-family: var(--font-mono); font-size: .72rem; color: var(--text-secondary);
        margin-top: .5rem; min-height: 1em; letter-spacing: .03em; }

    /* ── Buttons (terminal-styled) ── */
    .ext-btn {
        font-family: var(--font-display); font-weight: 600; font-size: .72rem; letter-spacing: .1em;
        text-transform: uppercase; border-radius: var(--radius-sm); padding: .45rem .9rem;
        border: 1px solid transparent; cursor: pointer; white-space: nowrap;
        transition: background var(--transition), color var(--transition), border-color var(--transition);
    }
    .ext-btn-primary { background: var(--accent); color: var(--bg-base); border-color: var(--accent); }
    .ext-btn-primary:hover { box-shadow: var(--accent-glow); }
    .ext-btn-secondary { background: transparent; color: var(--text-secondary); border-color: var(--border-subtle); }
    .ext-btn-secondary:hover { color: var(--accent); border-color: var(--accent-dim); background: #00d4ff0d; }
    .ext-btn-ref {
        margin-top: .4rem; padding: .3rem .7rem; font-size: .66rem;
        background: transparent; color: var(--accent); border-color: var(--accent-dim);
    }
    .ext-btn-ref:hover { background: #00d4ff14; }
    .ext-btn-ghost { background: transparent; color: var(--text-secondary); border-color: var(--border-subtle); }
    .ext-btn-ghost:hover { color: var(--red); border-color: #f8514955; }

    .ext-select {
        font-family: var(--font-mono); font-size: .78rem; max-width: 280px;
        background: var(--bg-surface); color: var(--text-primary);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: .35rem .5rem;
    }

    /* ── Panes ── */
    /* Break out of the 1200px .container so the three sections use the full screen width. */
    .extraction-split {
        display: flex; gap: 0; align-items: stretch;
        width: 100vw; margin-left: calc(50% - 50vw);
        padding: 0 .75rem; box-sizing: border-box;
    }
    .extraction-pane {
        min-width: 0; background: var(--bg-card); border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md); padding: 1.1rem 1.25rem;
    }
    /* Left pane is pinned to a width (drag-adjustable); right pane fills the rest. */
    #leftPane  { flex: 0 0 50%; }
    #rightPane { flex: 1; }

    /* Drag handle between the panes. */
    .extraction-gutter {
        flex: 0 0 1.25rem; align-self: stretch; cursor: col-resize;
        display: flex; align-items: center; justify-content: center; touch-action: none;
    }
    .extraction-gutter span {
        width: 2px; height: 38px; border-radius: 2px; background: var(--border-subtle);
        transition: background var(--transition), box-shadow var(--transition);
    }
    .extraction-gutter:hover span,
    .extraction-gutter.dragging span { background: var(--accent); box-shadow: var(--accent-glow); }
    body.ext-resizing { cursor: col-resize; user-select: none; }
    .extraction-pane-head {
        display: flex; justify-content: space-between; align-items: center; gap: .75rem;
        padding-bottom: .65rem; margin-bottom: .9rem; border-bottom: 1px solid var(--border-subtle);
    }
    .extraction-pane-title {
        font-family: var(--font-display); font-size: .75rem; font-weight: 600; letter-spacing: .16em;
        text-transform: uppercase; color: var(--text-secondary);
    }
    .extraction-pane-actions { display: flex; gap: .4rem; }

    .cell-row { margin-bottom: .85rem; }
    .ref-info { margin-top: .35rem; font-size: .74rem; line-height: 1.35; font-family: var(--font-mono); }
    .ref-info .ref-ok { color: var(--green); font-weight: bold; }
    .ref-info .ref-fail { color: var(--red); font-weight: bold; }
    .ref-info .ref-ptr { color: var(--muted); }
    .ref-info .ref-snip { color: var(--text-secondary); font-style: italic; }

    /* ── AI suggestions panel (Mode B) ── */
    .ai-suggest {
        margin: .25rem 0 1rem; border: 1px solid var(--border-accent); border-radius: var(--radius-sm);
        background: #00d4ff08;
    }
    .ai-suggest-head {
        display: flex; align-items: center; justify-content: space-between; gap: .5rem;
        padding: .5rem .7rem; border-bottom: 1px solid var(--border-subtle);
        font-family: var(--font-display); font-size: .7rem; font-weight: 600; letter-spacing: .12em;
        text-transform: uppercase; color: var(--text-secondary);
    }
    .ai-suggest-count { color: var(--accent); }
    .ai-suggest-close { padding: .1rem .45rem; font-size: .7rem; }
    .ai-suggest-list { max-height: 240px; overflow: auto; padding: .5rem; display: flex; flex-direction: column; gap: .4rem; }
    .ai-suggest-card {
        text-align: left; background: var(--bg-card); border: 1px solid var(--border-subtle);
        border-radius: var(--radius-sm); padding: .5rem .65rem; cursor: pointer;
        transition: border-color var(--transition), box-shadow var(--transition);
    }
    .ai-suggest-card:hover { border-color: var(--accent-dim); box-shadow: var(--accent-glow); }
    .ai-suggest-name { font-family: var(--font-mono); font-size: .8rem; color: var(--text-primary); font-weight: 600; }
    .ai-suggest-meta { font-family: var(--font-mono); font-size: .7rem; color: var(--muted); margin-top: .2rem; }
    .ai-suggest-meta .as-tag { color: var(--accent); }

    /* ── AI chat panel (Mode B, streaming) ── */
    .ai-chat {
        margin: .25rem 0 1rem; border: 1px solid var(--border-accent); border-radius: var(--radius-sm);
        background: #00d4ff08; display: flex; flex-direction: column;
    }
    .ai-chat-head {
        display: flex; align-items: center; justify-content: space-between; gap: .5rem;
        padding: .5rem .7rem; border-bottom: 1px solid var(--border-subtle);
        font-family: var(--font-display); font-size: .7rem; font-weight: 600; letter-spacing: .12em;
        text-transform: uppercase; color: var(--text-secondary);
    }
    .ai-chat-ctx { color: var(--accent); font-weight: 400; letter-spacing: .04em; }
    .ai-chat-close { padding: .1rem .45rem; font-size: .7rem; }
    .ai-chat-log { max-height: 320px; overflow: auto; padding: .6rem; display: flex; flex-direction: column; gap: .55rem; }
    .ai-chat-msg { display: flex; flex-direction: column; gap: .25rem; }
    .ai-chat-user .ai-chat-body {
        align-self: flex-end; background: var(--accent); color: var(--bg-base);
        border-radius: var(--radius-sm); padding: .4rem .6rem; max-width: 85%;
    }
    .ai-chat-assistant .ai-chat-body {
        align-self: flex-start; background: var(--bg-card); border: 1px solid var(--border-subtle);
        color: var(--text-primary); border-radius: var(--radius-sm); padding: .4rem .6rem; max-width: 92%;
        white-space: pre-wrap; word-break: break-word;
    }
    .ai-chat-body { font-family: var(--font-mono); font-size: .78rem; line-height: 1.5; }
    /* The dim live "thinking" trace (v4 reasoning tokens). */
    .ai-chat-think {
        align-self: flex-start; max-width: 92%; font-family: var(--font-mono); font-size: .7rem;
        line-height: 1.45; color: var(--muted); font-style: italic; white-space: pre-wrap;
        word-break: break-word; border-left: 2px solid var(--border-subtle); padding: .1rem .5rem;
        max-height: 120px; overflow: auto;
    }
    .ai-chat-input { display: flex; gap: .4rem; padding: .5rem; border-top: 1px solid var(--border-subtle); }
    .ai-chat-input textarea {
        flex: 1; resize: vertical; font-family: var(--font-mono); font-size: .78rem;
        background: var(--bg-base); color: var(--text-primary);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: .4rem .5rem;
    }
    #aiSaveList:empty { display: none; }
    #aiSaveList { padding: 0 .6rem .4rem; }

    /* ── Auto-scan triage report (all titles + the AI's picks) ── */
    .scan-report {
        margin: .5rem .6rem 0; border: 1px solid var(--border-subtle); border-radius: var(--radius-sm);
        background: var(--bg-base); max-height: 200px; overflow: auto; padding: .5rem .6rem;
    }
    .scan-report-head {
        font-family: var(--font-display); font-size: .66rem; font-weight: 600; letter-spacing: .1em;
        text-transform: uppercase; color: var(--accent); margin-bottom: .45rem;
    }
    .scan-report-sec {
        font-family: var(--font-mono); font-size: .68rem; color: var(--text-secondary);
        margin: .4rem 0 .2rem; letter-spacing: .04em;
    }
    .scan-report-row { display: flex; gap: .45rem; font-family: var(--font-mono); font-size: .74rem; padding: .1rem 0; }
    .scan-report-row .sr-mark { width: 1em; flex-shrink: 0; text-align: center; }
    .sr-picked { color: var(--text-primary); }
    .sr-picked .sr-mark { color: var(--green); }
    .sr-skipped { color: var(--muted); opacity: .6; }

    .ext-endpoint { font-family: var(--font-mono); font-size: .7rem; color: var(--muted);
        letter-spacing: .04em; margin-bottom: .5rem; min-height: 1em; }

    .extraction-json {
        max-height: 70vh; overflow: auto; white-space: pre-wrap; word-break: break-word;
        background: var(--bg-base); color: var(--text-code); padding: .75rem;
        font-family: var(--font-mono); font-size: .78rem; line-height: 1.55;
        border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); margin: 0;
    }
    .extraction-json::selection { background: var(--accent); color: var(--bg-base); }
    /* SEC filing rendered with its own inline formatting — light page inside the dark terminal. */
    .extraction-doc {
        max-height: 70vh; overflow: auto; background: #fff; color: #111; padding: 1rem;
        font-size: .85rem; border: 1px solid var(--border-subtle); border-radius: var(--radius-sm);
    }
    .extraction-doc ::selection, .extraction-doc::selection { background: var(--accent); color: var(--bg-base); }
    .extraction-doc img { max-width: 100%; height: auto; }
    .extraction-doc table { border-collapse: collapse; }
    /* Filing window + persistent TOC sit side by side; the TOC is OUTSIDE the scroll window. */
    .doc-shell { display: flex; gap: 1rem; align-items: flex-start; }
    .doc-shell .extraction-doc { flex: 1; min-width: 0; }
    .doc-toc {
        flex: 0 0 240px; align-self: flex-start; position: sticky; top: 1rem;
        max-height: 70vh; overflow: auto;
        background: var(--bg-card); border: 1px solid var(--border-subtle);
        border-radius: var(--radius-sm); padding: .6rem .7rem;
    }
    .doc-toc-head {
        font-family: var(--font-display); font-size: .68rem; font-weight: 600; letter-spacing: .14em;
        text-transform: uppercase; color: var(--text-secondary);
        padding-bottom: .45rem; margin-bottom: .45rem; border-bottom: 1px solid var(--border-subtle);
    }
    .doc-toc-link {
        display: block; font-family: var(--font-mono); font-size: .72rem; line-height: 1.3;
        color: var(--text-secondary); text-decoration: none; padding: .25rem .3rem;
        border-radius: var(--radius-sm);
    }
    .doc-toc-link:hover { color: var(--accent); background: #00d4ff14; }

    /* ── Wide filings overlay ── */
    .ext-modal { position: fixed; inset: 0; z-index: 1050; display: flex; align-items: center; justify-content: center; }
    .ext-modal-backdrop { position: absolute; inset: 0; background: rgba(4, 8, 13, .78); backdrop-filter: blur(2px); }
    .ext-modal-panel {
        position: relative; width: 92vw; max-width: 1500px; height: 85vh; display: flex; flex-direction: column;
        background: var(--bg-surface); border: 1px solid var(--border-accent); border-radius: var(--radius-md);
        box-shadow: var(--accent-glow), 0 18px 60px rgba(0,0,0,.6); overflow: hidden;
    }
    .ext-modal-head {
        display: flex; align-items: center; gap: 1rem; padding: .85rem 1.1rem;
        border-bottom: 1px solid var(--border-subtle); background: var(--bg-card);
    }
    .ext-modal-titlewrap { display: flex; align-items: baseline; gap: .6rem; flex-shrink: 0; }
    .ext-modal-title {
        font-family: var(--font-display); font-size: .9rem; font-weight: 700; letter-spacing: .14em;
        text-transform: uppercase; color: var(--text-primary);
    }
    .ext-modal-count { font-family: var(--font-mono); font-size: .72rem; color: var(--accent); }
    .ext-modal-filter {
        flex: 1; max-width: 420px; font-family: var(--font-mono); font-size: .78rem;
        background: var(--bg-base); color: var(--text-primary);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: .35rem .6rem;
    }
    .ext-modal-head .ext-btn-ghost { margin-left: auto; }
    .ext-modal-empty { padding: 2rem; text-align: center; font-family: var(--font-mono);
        font-size: .8rem; color: var(--muted); }

    .ext-filings-grid {
        flex: 1; overflow-y: auto; padding: 1.1rem; display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: .75rem; align-content: start;
    }
    .ext-filing-card {
        background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm);
        padding: .7rem .85rem; cursor: pointer; text-align: left;
        transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
        display: flex; flex-direction: column; gap: .4rem;
    }
    .ext-filing-card:hover { border-color: var(--accent-dim); box-shadow: var(--accent-glow); transform: translateY(-2px); }
    .ext-filing-top { display: flex; align-items: center; justify-content: space-between; gap: .5rem; }
    .ext-filing-form {
        font-family: var(--font-display); font-weight: 700; font-size: .72rem; letter-spacing: .1em;
        color: var(--accent); background: #00d4ff12; border: 1px solid var(--border-accent);
        padding: .12rem .5rem; border-radius: var(--radius-sm);
    }
    .ext-filing-date { font-family: var(--font-mono); font-size: .72rem; color: var(--text-secondary); font-variant-numeric: tabular-nums; }
    .ext-filing-desc { font-family: var(--font-mono); font-size: .73rem; color: var(--muted); line-height: 1.4;
        overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    .ext-filing-card.no-doc { opacity: .5; cursor: not-allowed; }
    .ext-filing-card.no-doc:hover { border-color: var(--border-subtle); box-shadow: none; transform: none; }

    @@media (max-width: 800px) {
        .extraction-split { flex-direction: column; }
        #leftPane { flex: 1 1 auto; }
        .extraction-gutter { display: none; }
    }
</style>
<script>
(function () {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const companyHidden = () => document.querySelector('input[name="companyId"]');
    const relatedHidden = () => document.querySelector('input[name="relatedCompanyId"]');
    const pre = document.getElementById('response');
    const docPane = document.getElementById('responseHtml');
    const docToc = document.getElementById('docToc');
    const endpointLabel = document.getElementById('endpointLabel');
    const rowPicker = document.getElementById('rowPicker');
    let edgarRows = [];        // revenue rows pulled from the refresh response (left pre-fill)
    let currentRowId = null;   // bound source row; null => first reference creates it
    let currentEndpoint = '';  // the EDGAR response currently shown (stored as provenance)
    let currentFiling = null;  // the filing doc currently open (null when viewing Company Facts)
    let aiProof = {};          // field -> AI-suggested proof snapshot (Mode B); used when nothing is hand-selected

    const $ = id => document.getElementById(id);
    const numOrNull = v => v === '' || v == null ? null : Number(v);
    const companyId = () => companyHidden()?.value;

    // ---- Node (Revenue / Cost / Risk): drives form fields, EDGAR section filter and AI prompts ----
    const nodeCfg = (() => {
        try { return JSON.parse($('nodeConfig').textContent); }
        catch { return { initial: 'REVENUE', classes: {} }; }
    })();
    let node = nodeCfg.initial || 'REVENUE';
    const NODE_LABEL = { REVENUE: 'Revenue', COST: 'Cost', RISK: 'Risk' };
    const isRisk = () => node === 'RISK';

    // Repopulate the classification dropdown with the active node's enum values.
    function rebuildClassOptions() {
        const opts = (nodeCfg.classes && nodeCfg.classes[node]) || [];
        const sel = $('f_sourceType');
        sel.innerHTML = '';
        opts.forEach(v => {
            const o = document.createElement('option');
            o.value = v; o.textContent = v; sel.appendChild(o);
        });
    }

    // Reflect the current node in the page chrome: title, label, which cells show, load-button text.
    function applyNode() {
        $('nodeTitle').textContent = NODE_LABEL[node] || node;
        $('classLabel').textContent = isRisk() ? 'Scope' : 'Classification';
        rebuildClassOptions();
        $('valueRow').hidden = isRisk();
        $('pctRow').hidden = isRisk();
        $('counterpartyRow').hidden = isRisk();
        $('noteRow').hidden = !isRisk();
        $('loadBtn').textContent = isRisk() ? 'LOAD COMPANY' : 'LOAD EDGAR ROWS';
    }

    // ---- Drag the gutter to widen the filing pane (only left pane's width changes) ----
    (function () {
        const split = $('extractionSplit'), gutter = $('extGutter'), left = $('leftPane');
        const MIN_LEFT = 150, MIN_RIGHT = 420;  // keep both panes usable
        gutter.addEventListener('pointerdown', e => {
            e.preventDefault();
            gutter.setPointerCapture(e.pointerId);
            gutter.classList.add('dragging');
            document.body.classList.add('ext-resizing');
            const onMove = ev => {
                const rect = split.getBoundingClientRect();
                let w = ev.clientX - rect.left;            // proposed left width
                const max = rect.width - MIN_RIGHT - gutter.offsetWidth;
                w = Math.max(MIN_LEFT, Math.min(w, max));
                left.style.flexBasis = w + 'px';           // right pane reflows to fill
            };
            const onUp = ev => {
                gutter.releasePointerCapture(e.pointerId);
                gutter.classList.remove('dragging');
                document.body.classList.remove('ext-resizing');
                gutter.removeEventListener('pointermove', onMove);
                gutter.removeEventListener('pointerup', onUp);
            };
            gutter.addEventListener('pointermove', onMove);
            gutter.addEventListener('pointerup', onUp);
        });
        // Double-click the gutter to reset to an even split.
        gutter.addEventListener('dblclick', () => { left.style.flexBasis = '50%'; });
    })();

    function showText(text, endpoint) {
        docPane.hidden = true;          // text view: hide the formatted doc pane
        docToc.hidden = true;           // and its sidebar TOC
        pre.hidden = false;
        pre.textContent = text;
        currentEndpoint = endpoint;
        currentFiling = null;   // generic text view: no filing backs it (openFiling re-sets this)
        endpointLabel.textContent = endpoint ? `source: ${endpoint}` : '';
    }

    // Show a filing's own HTML (SEC inline formatting) in the doc pane. Same-origin (proxied), so
    // select-to-reference still reads the browser selection from these nodes.
    function showHtml(html, baseUrl, endpoint, filing) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html;
        // Drop anything that could escape into the page or run; keep inline style attrs (SEC's
        // table/font formatting lives there).
        tmp.querySelectorAll('script,style,link,meta,noscript,base,title').forEach(e => e.remove());
        // Resolve relative image/link URLs against the filing's real document URL.
        if (baseUrl) {
            tmp.querySelectorAll('img[src]').forEach(el => {
                try { el.src = new URL(el.getAttribute('src'), baseUrl).href; } catch { }
            });
            tmp.querySelectorAll('a[href]').forEach(el => {
                const raw = el.getAttribute('href') || '';
                // Table-of-contents links (href="#anchor") stay in-page: leave them
                // as a bare fragment so the click handler scrolls the doc pane.
                if (raw.startsWith('#')) { el.setAttribute('href', raw); return; }
                try { el.href = new URL(raw, baseUrl).href; } catch { }
                el.target = '_blank'; el.rel = 'noopener';
            });
        }
        // Build a persistent TOC from the filing's own in-page anchors (only those whose
        // target exists). Label comes from the anchor's whole table row, because SEC splits
        // "Item 1." and "Business" into separate cells — the anchor text alone is just the number.
        const tocItems = [];
        const seen = new Set();
        tmp.querySelectorAll('a[href^="#"]').forEach(a => {
            const id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
            if (!id || seen.has(id)) return;
            if (!tmp.querySelector(`#${CSS.escape(id)}, [name="${CSS.escape(id)}"]`)) return;
            const row = a.closest('tr');
            let label = ((row ? row.textContent : a.textContent) || '').replace(/\s+/g, ' ').trim();
            label = label.replace(/\s+\d+$/, '').trim();          // drop trailing page number
            if (!label) label = (a.textContent || '').replace(/\s+/g, ' ').trim();
            if (!label) return;
            seen.add(id);
            tocItems.push({ id, label });
        });

        pre.hidden = true;
        docPane.hidden = false;
        docPane.innerHTML = tmp.innerHTML;
        docPane.scrollTop = 0;

        // Populate the sibling TOC sidebar (lives outside the scroll window, on the right).
        if (tocItems.length) {
            docToc.innerHTML = `<div class="doc-toc-head">Contents</div>` + tocItems.map(t =>
                `<a href="#${escapeHtml(t.id)}" class="doc-toc-link">${escapeHtml(t.label)}</a>`).join('');
            docToc.hidden = false;
        } else {
            docToc.innerHTML = '';
            docToc.hidden = true;
        }
        currentEndpoint = endpoint;
        currentFiling = filing;   // proof taken here links the source row to this filing
        endpointLabel.textContent = endpoint ? `source: ${endpoint}` : '';
    }

    // In-page table-of-contents links (both the body's own and the sidebar nav): scroll the
    // target into the doc window instead of navigating. SEC anchors are often legacy
    // <a name="x"> (no id), so match both.
    function tocScroll(e) {
        const a = e.target.closest('a[href^="#"]');
        if (!a) return;
        e.preventDefault();
        const id = decodeURIComponent(a.getAttribute('href').slice(1));
        if (!id) return;
        const target = docPane.querySelector(`#${CSS.escape(id)}, [name="${CSS.escape(id)}"]`);
        if (target) target.scrollIntoView({ block: 'start' });
    }
    docPane.addEventListener('click', tocScroll);
    docToc.addEventListener('click', tocScroll);

    const escapeHtml = s => (s || '').replace(/[&<>"]/g,
        c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const shortText = (s, n = 90) => {
        s = (s || '').replace(/\s+/g, ' ').trim();
        return s.length > n ? s.slice(0, n) + '…' : s;
    };

    // Render the saved pointer (✓ + char offsets + snapshot preview) under a cell.
    function renderRef(field, ref) {
        const el = document.querySelector(`.ref-info[data-info="${field}"]`);
        if (!el) return;
        if (!ref) { el.innerHTML = ''; el.removeAttribute('title'); return; }
        const badge = ref.mark === 1 ? `<span class="ref-ok">✓ PASS</span>`
            : ref.mark === 0 ? `<span class="ref-fail">✗ FAIL</span>`
            : `<span class="ref-ok">✓</span>`;
        el.innerHTML =
            `${badge} ` +
            `<span class="ref-ptr">${escapeHtml(ref.pointer || '')}</span> ` +
            `<span class="ref-snip">“${escapeHtml(shortText(ref.snapshot))}”</span>`;
        el.title = `${ref.rationale ? 'AI: ' + ref.rationale + '\n\n' : ''}${ref.endpoint ? ref.endpoint + '\n\n' : ''}${ref.snapshot || ''}`;
    }
    function clearRefs() { document.querySelectorAll('.ref-info').forEach(el => renderRef(el.dataset.info, null)); }

    // Show whatever references already exist for the bound row (survives reloads).
    async function loadExistingRefs(rowId) {
        clearRefs();
        if (!rowId) return;
        try {
            const res = await fetch(`/extraction/references/${rowId}?node=${node}`);
            if (!res.ok) return;
            (await res.json()).forEach(r => renderRef(r.field, r));
        } catch { /* non-fatal */ }
    }

    function fillCells(r) {
        // The classification field is named differently per node in the DTO (sourceType/costBase/scope).
        const cls = r ? (r.sourceType ?? r.costBase ?? r.scope) : null;
        $('f_sourceType').value = cls != null ? cls : ($('f_sourceType').options[0]?.value ?? '');
        $('f_name').value = r ? (r.name ?? '') : '';
        $('f_value').value = r && r.value != null ? r.value : '';
        $('f_percentage').value = r && r.percentage != null ? r.percentage : '';
        $('f_note').value = r && r.note != null ? r.note : '';
        currentRowId = r ? r.id : null;
        aiProof = {};            // a different row's cells aren't backed by the last AI suggestion
        loadExistingRefs(currentRowId);
    }

    // ---- LOAD: refresh persists+pre-fills the left, then show Company Facts on the right ----
    $('loadBtn').addEventListener('click', async () => {
        const id = companyId();
        const status = $('loadStatus');
        if (!id) { status.textContent = 'Pick a company first.'; return; }
        status.textContent = 'Refreshing rows…';
        try {
            const res = await fetch(`/api/stock/refresh/${id}`, { method: 'POST' });
            if (!res.ok) { status.textContent = `Refresh failed (${res.status}): ${await res.text()}`; return; }
            const dto = await res.json();

            // Risk has no structured EDGAR rows — its rows come from the filing via AI, not refresh.
            const src = node === 'COST' ? (dto.costSources || [])
                      : node === 'RISK' ? []
                      : (dto.revenueSources || []);
            const byKey = new Map();
            src.filter(r => r.dataSource === 'EDGAR')
                .forEach(r => byKey.set(r.name, r)); // later (higher-id) wins
            edgarRows = [...byKey.values()];
            rowPicker.innerHTML = '<option value="">— new row —</option>';
            edgarRows.forEach(r => {
                const o = document.createElement('option');
                o.value = r.id; o.textContent = `${r.name} (#${r.id})`;
                rowPicker.appendChild(o);
            });
            if (edgarRows.length) { rowPicker.value = edgarRows[0].id; fillCells(edgarRows[0]); }
            else fillCells(null);
            status.textContent = isRisk()
                ? 'Loaded. Open a filing and use AI Chat to extract risks.'
                : `Pre-filled ${edgarRows.length} EDGAR row(s).`;
        } catch (e) { status.textContent = 'Network error: ' + e.message; return; }
        loadFacts();
    });

    rowPicker.addEventListener('change', () => {
        const r = edgarRows.find(x => String(x.id) === rowPicker.value);
        fillCells(r || null);
    });

    // Initialise the node UI, then react to the dropdown: switching node resets the row + cells and
    // drops any open chat (a new node grounds on different sections).
    $('nodeSelect').value = node;
    applyNode();
    $('nodeSelect').addEventListener('change', () => {
        node = $('nodeSelect').value;
        edgarRows = [];
        rowPicker.innerHTML = '<option value="">— new row —</option>';
        applyNode();
        fillCells(null);
        chatHistory = []; aiChatLog.innerHTML = ''; aiSaveList.innerHTML = ''; chatFiling = null;
    });

    // ---- right pane: Company Facts ----
    async function loadFacts() {
        const id = companyId();
        if (!id) { uiAlert('Pick a company first.'); return; }
        showText('Loading company facts…', '');
        const res = await fetch(`/api/stock/facts/${id}`);
        if (!res.ok) { showText(`Facts failed (${res.status}): ${await res.text()}`, ''); return; }
        let body = await res.text();
        try { body = JSON.stringify(JSON.parse(body), null, 2); } catch { /* leave raw */ }
        showText(body, `GET /api/stock/facts/${id}`);
    }
    $('factsBtn').addEventListener('click', loadFacts);

    // ---- Wide filings browser (overlay) ----
    const filingsModal = $('filingsModal');
    const filingsGrid = $('filingsGrid');
    const filingsFilter = $('filingsFilter');
    let allFilings = [];

    function closeFilingsModal() { filingsModal.hidden = true; }
    function openFilingsModal() { filingsModal.hidden = false; filingsFilter.value = ''; filingsFilter.focus(); }

    function renderFilings(list) {
        filingsGrid.innerHTML = '';
        list.forEach(f => {
            const card = document.createElement('button');
            card.type = 'button';
            const hasDoc = !!(f.accessionNumber && f.primaryDocument);
            card.className = 'ext-filing-card' + (hasDoc ? '' : ' no-doc');
            card.innerHTML =
                `<div class="ext-filing-top">` +
                    `<span class="ext-filing-form">${escapeHtml(f.form || '—')}</span>` +
                    `<span class="ext-filing-date">${escapeHtml(f.filingDate || '')}</span>` +
                `</div>` +
                (f.description ? `<div class="ext-filing-desc">${escapeHtml(f.description)}</div>` : '');
            if (hasDoc) card.addEventListener('click', () => { closeFilingsModal(); openFiling(companyId(), f); });
            filingsGrid.appendChild(card);
        });
        $('filingsCount').textContent = `${list.length} shown`;
        $('filingsEmpty').hidden = list.length > 0;
    }

    filingsFilter.addEventListener('input', () => {
        const q = filingsFilter.value.trim().toLowerCase();
        if (!q) { renderFilings(allFilings); return; }
        renderFilings(allFilings.filter(f =>
            `${f.form || ''} ${f.filingDate || ''} ${f.description || ''}`.toLowerCase().includes(q)));
    });

    filingsModal.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', closeFilingsModal));
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !filingsModal.hidden) closeFilingsModal(); });

    $('filingsBtn').addEventListener('click', async () => {
        const id = companyId();
        if (!id) { uiAlert('Pick a company first.'); return; }
        filingsGrid.innerHTML = '';
        $('filingsCount').textContent = 'loading…';
        $('filingsEmpty').hidden = true;
        openFilingsModal();
        const res = await fetch(`/api/stock/filings/${id}`);
        if (!res.ok) { $('filingsCount').textContent = `failed (${res.status})`; return; }
        allFilings = await res.json();
        renderFilings(allFilings);
    });

    async function openFiling(id, f) {
        if (!f.accessionNumber || !f.primaryDocument) { uiAlert('Filing has no primary document.'); return; }
        showText('Loading filing…', '');
        const qs = `accession=${encodeURIComponent(f.accessionNumber)}&doc=${encodeURIComponent(f.primaryDocument)}`;
        const res = await fetch(`/api/stock/filing/${id}?${qs}`);
        if (!res.ok) { showText(`Filing failed (${res.status}): ${await res.text()}`, ''); return; }
        const raw = await res.text();
        const endpoint = f.documentUrl || `GET /api/stock/filing/${id}?${qs}`;
        const isHtml = /\.html?$/i.test(f.primaryDocument) || /<html|<body|<div/i.test(raw.slice(0, 2000));
        // HTML filings keep SEC's own formatting in the doc pane; plain-text docs stay in the pre.
        if (isHtml) showHtml(raw, f.documentUrl, endpoint, f);
        else { showText(raw, endpoint); currentFiling = f; }
    }

    // ---- capture the selected proof text within the response pane ----
    function selectionInfo() {
        const sel = window.getSelection();
        const text = sel ? sel.toString() : '';
        let pointer = 'selection';
        if (sel && sel.rangeCount && text) {
            const range = sel.getRangeAt(0);
            const node = pre.firstChild;
            if (node && range.startContainer === node && range.endContainer === node)
                pointer = `chars ${range.startOffset}-${range.endOffset}`;
        }
        return { text, pointer };
    }
    function cellValue(field) {
        switch (field) {
            case 'VALUE': return $('f_value').value || null;
            case 'PERCENTAGE': return $('f_percentage').value || null;
            case 'NAME': return $('f_name').value || null;
            case 'CLASSIFICATION': return $('f_sourceType').value || null;
            case 'NOTE': return $('f_note').value || null;
            case 'RELATED_COMPANY': {
                const inp = relatedHidden()?.closest('.autocomplete')?.querySelector('.autocomplete-input');
                return inp ? (inp.value || null) : null;
            }
        }
        return null;
    }

    // ---- SAVE: one button writes the row + every field that carries proof ----
    async function saveRow() {
        const id = Number(companyId());
        if (!id) { uiAlert('Pick a company first.'); return; }
        if (!$('f_name').value.trim()) { uiAlert('Name is required before saving.'); return; }
        const status = $('saveStatus');
        status.textContent = 'Saving…';

        // Attach proof for any field the AI backed (stashed in aiProof). Fields you typed by hand
        // with no proof still save their value — they just have no reference row.
        const proofs = Object.entries(aiProof)
            .filter(([, snap]) => snap && snap.trim())
            .map(([field, snapshot]) => ({
                field,
                endpoint: currentEndpoint || 'AI extraction',
                referencePointer: 'ai-suggested',
                referenceSnapshot: snapshot,
                referencedValue: cellValue(field),
                filingAccessionNumber: currentFiling?.accessionNumber || null,
                filingForm: currentFiling?.form || null,
                filingDate: currentFiling?.filingDate || null,
                filingUrl: currentFiling?.documentUrl || null
            }));

        const body = {
            companyId: id,
            revenueSourceId: currentRowId,
            node,
            sourceType: $('f_sourceType').value,   // generic classification (SourceType/CostBase/RiskScope)
            name: $('f_name').value,
            value: numOrNull($('f_value').value),
            percentage: numOrNull($('f_percentage').value),
            note: $('f_note').value || null,
            relatedCompanyId: relatedHidden()?.value ? Number(relatedHidden().value) : null,
            proofs
        };
        try {
            const res = await fetch('/extraction/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(body)
            });
            if (!res.ok) { status.textContent = 'Save failed: ' + await res.text(); return; }
            const r = await res.json();
            currentRowId = r.revenueSourceId;            // bind the (possibly new) row
            status.textContent = `Saved row #${r.revenueSourceId}` + (r.proofs ? ` · ${r.proofs} proof(s)` : ' · no proof attached');
            loadExistingRefs(currentRowId);              // refresh the per-field proof readout
        } catch (e) { status.textContent = 'Network error: ' + e.message; }
    }
    $('saveBtn').addEventListener('click', saveRow);

    // ---- Mode B: conversational extraction (streaming chat grounded on the open filing) ----
    const validClassification = c => c && Array.from($('f_sourceType').options).some(o => o.value === c);

    function fillFromSuggestion(s) {
        rowPicker.value = '';            // an AI suggestion is a new proposed row, not an EDGAR one
        currentRowId = null;
        if (validClassification(s.classification)) $('f_sourceType').value = s.classification;
        $('f_name').value = s.name || '';
        $('f_value').value = s.value != null ? s.value : '';
        $('f_percentage').value = s.percentage != null ? s.percentage : '';
        $('f_note').value = s.note != null ? s.note : '';
        // Counterparty needs a DB id (name resolution stays manual) — surface the name as a hint.
        const relInput = relatedHidden()?.closest('.autocomplete')?.querySelector('.autocomplete-input');
        if (relInput && s.relatedCompany) relInput.value = s.relatedCompany;

        // Stash per-field proof so "Use as reference" freezes it with no manual selection needed.
        aiProof = {};
        const p = s.proof || {};
        const map = { NAME: p.name, VALUE: p.value, PERCENTAGE: p.percentage,
                      CLASSIFICATION: p.classification, RELATED_COMPANY: p.relatedCompany, NOTE: p.note };
        clearRefs();
        Object.entries(map).forEach(([field, snap]) => {
            if (snap && snap.trim()) {
                aiProof[field] = snap;
                renderRef(field, { pointer: 'ai-suggested', snapshot: snap, endpoint: currentEndpoint });
            }
        });
    }

    // A ```save {json}``` block in the reply → normalize snake_case to the form-fill shape.
    function normalizeSave(j) {
        return {
            name: j.name || '',
            classification: j.classification || null,
            value: j.value != null && j.value !== '' ? Number(j.value) : null,
            percentage: j.percentage != null && j.percentage !== '' ? Number(j.percentage) : null,
            relatedCompany: j.related_company || j.relatedCompany || null,
            note: j.note ?? null,
            section: 'AI chat',
            proof: {
                name: j.proof?.name ?? null, value: j.proof?.value ?? null,
                percentage: j.proof?.percentage ?? null, classification: j.proof?.classification ?? null,
                relatedCompany: j.proof?.related_company ?? j.proof?.relatedCompany ?? null,
                note: j.proof?.note ?? null
            }
        };
    }

    // ---- chat panel state ----
    const aiChat = $('aiChat'), aiChatLog = $('aiChatLog'), aiChatText = $('aiChatText'), aiSaveList = $('aiSaveList');
    let chatHistory = [];      // visible turns only; the filing grounding is added server-side
    let chatFiling = null;     // accession the open chat is grounded on (reset when a new filing opens)
    let chatBusy = false;

    $('aiChatClose').addEventListener('click', () => { aiChat.hidden = true; });

    function chatBubble(role) {
        const wrap = document.createElement('div');
        wrap.className = 'ai-chat-msg ai-chat-' + role;
        const think = document.createElement('div'); think.className = 'ai-chat-think'; think.hidden = true;
        const body = document.createElement('div'); body.className = 'ai-chat-body';
        wrap.append(think, body);
        aiChatLog.appendChild(wrap);
        aiChatLog.scrollTop = aiChatLog.scrollHeight;
        return { think, body };
    }

    // Reply prose hides the raw save blocks; each becomes a clickable "fill the form" card.
    const stripSave = t => t.replace(/```save[\s\S]*?```/g, '📌 (proposed save below)');
    function renderSaveCards(text) {
        const re = /```save\s*([\s\S]*?)```/g; let m;
        while ((m = re.exec(text)) !== null) {
            let j; try { j = JSON.parse(m[1].trim()); } catch { continue; }
            const s = normalizeSave(j);
            if (!s.name) continue;
            const card = document.createElement('button');
            card.type = 'button'; card.className = 'ai-suggest-card';
            const bits = [];
            if (s.value != null) bits.push('$' + Number(s.value).toLocaleString());
            if (s.percentage != null) bits.push(s.percentage + '%');
            if (s.relatedCompany) bits.push('↔ ' + s.relatedCompany);
            if (s.note) bits.push('“' + shortText(s.note, 50) + '”');
            card.innerHTML =
                `<div class="ai-suggest-name">＋ ${escapeHtml(s.name)}</div>` +
                `<div class="ai-suggest-meta"><span class="as-tag">${escapeHtml(s.classification || '—')}</span>` +
                (bits.length ? ' · ' + escapeHtml(bits.join(' · ')) : '') + `</div>`;
            card.addEventListener('click', () => fillFromSuggestion(s));
            aiSaveList.appendChild(card);
        }
    }

    async function sendChat(text) {
        if (chatBusy || !text.trim()) return;
        const id = companyId();
        if (!id) { uiAlert('Pick a company first.'); return; }
        if (!currentFiling?.accessionNumber || !currentFiling?.primaryDocument) {
            uiAlert('Open a filing in the right pane first (Filings → pick one).'); return;
        }
        chatBusy = true; aiChatText.value = '';
        chatHistory.push({ role: 'user', content: text });
        chatBubble('user').body.textContent = text;
        const out = chatBubble('assistant');
        let full = '', think = '';
        try {
            const res = await fetch('/extraction/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({
                    companyId: Number(id),
                    accession: currentFiling.accessionNumber,
                    doc: currentFiling.primaryDocument,
                    node,
                    form: currentFiling.form || null,
                    messages: chatHistory
                })
            });
            if (!res.ok || !res.body) { out.body.textContent = `[error ${res.status}]`; chatBusy = false; return; }
            const reader = res.body.getReader(), dec = new TextDecoder();
            let buf = '';
            while (true) {
                const { value, done } = await reader.read();
                if (done) break;
                buf += dec.decode(value, { stream: true });
                let nl;
                while ((nl = buf.indexOf('\n')) >= 0) {
                    const line = buf.slice(0, nl).trim(); buf = buf.slice(nl + 1);
                    if (!line) continue;
                    let ev; try { ev = JSON.parse(line); } catch { continue; }
                    if (ev.t === 'status') { if (!full) out.body.textContent = '⏳ ' + ev.c; }
                    else if (ev.t === 'reasoning') { think += ev.c; out.think.hidden = false; out.think.textContent = think; }
                    else if (ev.t === 'text') { full += ev.c; out.body.textContent = stripSave(full); }
                    else if (ev.t === 'error') { out.body.textContent += `\n[${ev.c}]`; }
                    aiChatLog.scrollTop = aiChatLog.scrollHeight;
                }
            }
            chatHistory.push({ role: 'assistant', content: full });
            renderSaveCards(full);
        } catch (e) { out.body.textContent = '[network error]'; }
        chatBusy = false;
    }

    $('aiChatSend').addEventListener('click', () => sendChat(aiChatText.value));
    aiChatText.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(aiChatText.value); }
    });

    // Open the chat from the right pane. A different filing (or reset=true after a curated scan)
    // clears the conversation; the first open seeds the "find the sources" question.
    function openChat(reset) {
        if (!currentFiling?.accessionNumber || !currentFiling?.primaryDocument) {
            uiAlert('Open a filing in the right pane first (Filings → pick one).'); return;
        }
        aiChat.hidden = false;
        if (reset || chatFiling !== currentFiling.accessionNumber) {
            chatFiling = currentFiling.accessionNumber;
            chatHistory = []; aiChatLog.innerHTML = ''; aiSaveList.innerHTML = '';
            clearScanReport();   // the previous filing's triage list no longer applies
        }
        $('aiChatCtx').textContent = currentFiling.form ? `· ${currentFiling.form} ${currentFiling.filingDate || ''}` : '';
        aiChatText.focus();
        const seed = {
            COST: 'List the most significant cost sources and key suppliers in this filing, with values or percentages where stated, then ask me which I want to save.',
            RISK: 'List the most significant risks disclosed in this filing, grouped by scope (macroeconomic, industry, business, legal/regulatory, financial, general), then ask me which I want to save.',
            REVENUE: 'List the most interesting revenue sources in this filing, with values or percentages where stated, then ask me which I want to save.'
        };
        if (!chatHistory.length) sendChat(seed[node] || seed.REVENUE);
    }
    $('aiChatBtn').addEventListener('click', () => openChat(false));

    // Read-only triage report: list every heading the model saw, grouped by Item, with the ones it
    // chose to scan marked (✓) and the rest dimmed — so the user sees what was offered and picked.
    const scanReport = $('scanReport');
    function clearScanReport() { scanReport.hidden = true; scanReport.innerHTML = ''; }
    function renderScanReport(r) {
        if (!r.headings || !r.headings.length) { clearScanReport(); return; }
        const chosen = r.headings.filter(h => h.picked).length;
        const bySec = {};
        r.headings.forEach(h => { (bySec[h.section] ||= []).push(h); });
        let html = `<div class="scan-report-head">AI triaged ${r.headings.length} titles · chose ${chosen} · ${r.found} candidates</div>`;
        Object.entries(bySec).forEach(([sec, items]) => {
            html += `<div class="scan-report-sec">${escapeHtml(sec)}</div>`;
            items.forEach(h => {
                html += `<div class="scan-report-row ${h.picked ? 'sr-picked' : 'sr-skipped'}">` +
                    `<span class="sr-mark">${h.picked ? '✓' : '·'}</span>` +
                    `<span class="sr-title">${escapeHtml(h.title)}</span></div>`;
            });
        });
        scanReport.innerHTML = html;
        scanReport.hidden = false;
    }

    // ---- Auto-Scan: AI triages every heading by title, scans the relevant ones in parallel, then
    // grounds the chat on the digest. No picking — the model decides which sections to read. ----
    $('autoScanBtn').addEventListener('click', async () => {
        const id = companyId();
        if (!id) { uiAlert('Pick a company first.'); return; }
        if (!currentFiling?.accessionNumber || !currentFiling?.primaryDocument) {
            uiAlert('Open a filing in the right pane first (Filings → pick one).'); return;
        }
        const btn = $('autoScanBtn'), label = btn.textContent;
        btn.disabled = true; btn.textContent = 'Scanning…';
        const qs = `accession=${encodeURIComponent(currentFiling.accessionNumber)}&doc=${encodeURIComponent(currentFiling.primaryDocument)}&node=${node}&form=${encodeURIComponent(currentFiling.form || '')}`;
        try {
            const res = await fetch(`/extraction/scan-auto/${id}?${qs}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            if (!res.ok) { uiAlert('Scan failed: ' + await res.text()); return; }
            const r = await res.json();
            openChat(true);     // digest is now cached → the chat grounds on it
            renderScanReport(r); // show every title + which ones the AI chose
        } catch (e) { uiAlert('Network error: ' + e.message); }
        finally { btn.disabled = false; btn.textContent = label; }
    });

    // ---- Mode A: run the phase-2 AI reviewer over this company's saved cells ----
    $('reviewBtn').addEventListener('click', async () => {
        const id = companyId();
        if (!id) { uiAlert('Pick a company first.'); return; }
        const status = $('loadStatus');
        status.textContent = 'AI reviewing saved cells…';
        try {
            const res = await fetch(`/extraction/review/${id}`,
                { method: 'POST', headers: { 'RequestVerificationToken': token } });
            if (!res.ok) { status.textContent = `Review failed (${res.status}): ${await res.text()}`; return; }
            const r = await res.json();
            status.textContent =
                `Reviewed ${r.reviewed}: ${r.passed} pass, ${r.failed} fail` +
                (r.skipped ? `, ${r.skipped} skipped` : '') + '.';
            loadExistingRefs(currentRowId);   // refresh marks on the bound row
        } catch (e) { status.textContent = 'Network error: ' + e.message; }
    });

    // ---- Prefill: opened from a source's "Add references" — bind that row and show its proof ----
    (function bootstrapPrefill() {
        const island = document.getElementById('prefillData');
        if (!island) return;
        let row;
        try { row = JSON.parse(island.textContent); } catch { return; }
        edgarRows = [row];
        const o = document.createElement('option');
        o.value = row.id; o.textContent = `${row.name} (#${row.id})`;
        rowPicker.appendChild(o);
        rowPicker.value = row.id;
        fillCells(row);          // sets cells + currentRowId + loads existing refs
        loadFacts();             // open the right pane so the user can browse/select proof
    })();
})();
</script>
}
