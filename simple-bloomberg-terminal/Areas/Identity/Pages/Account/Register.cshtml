@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Create account</h1>

        <form id="registerForm" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <div class="auth-field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@example.com"/>
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="••••••••"/>
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="••••••••"/>
                <span asp-validation-for="Input.ConfirmPassword" class="auth-validation"></span>
            </div>

            <button type="submit" class="auth-btn-primary">Register</button>
        </form>

        @if (Model.ExternalLogins.Count > 0)
        {
            <div class="auth-divider"><span>or</span></div>
            <form method="post" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" class="auth-external">
                @foreach (var provider in Model.ExternalLogins)
                {
                    <button type="submit" name="provider" value="@provider.Name" class="google-btn"
                            title="Sign in with @provider.DisplayName">
                        <svg viewBox="0 0 48 48" aria-hidden="true">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                        </svg>
                        <span>Sign in with @provider.DisplayName</span>
                    </button>
                }
            </form>
        }

        <p class="auth-foot">Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
