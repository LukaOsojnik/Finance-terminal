@model IEnumerable<simple_bloomberg_terminal.Models.ViewModels.EventRowViewModel>
@{
    ViewData["Title"] = "Events";
}

<div class="page-header">
    <h2><span class="page-header-accent">//</span> Events</h2>
    <div class="page-subtitle">MARKET EVENTS — IMPACT SCORES · AFFECTED ENTITIES</div>
</div>

@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="d-flex" style="margin-bottom:1rem; gap:0.75rem; align-items:center;">
    <input type="text" class="form-control search-input" placeholder="Search title / description..." data-search-url="@Url.Action("Search")" style="max-width:420px;"/>
    <a asp-action="Create" class="btn btn-primary">+ NEW</a>
</div>

<table class="terminal-table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Type</th>
            <th>Date</th>
            <th style="text-align:right;">Impact</th>
            <th>Countries</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="table-body">
        @await Html.PartialAsync("_TableBody", Model)
    </tbody>
</table>
