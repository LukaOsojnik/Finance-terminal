@using simple_bloomberg_terminal.Models.Entities
@model IEnumerable<RevenueSource>

@if (!Model.Any()) { <tr><td colspan="6" class="muted-cell" style="text-align:center; padding:1rem;">No results</td></tr> }
@foreach (var r in Model)
{
    <tr>
        <td class="name-cell">@(r.Company?.Name ?? r.CompanyId.ToString())</td>
        <td class="tag-cell">@r.Name</td>
        <td class="tag-cell">@r.SourceType</td>
        <td class="num-cell">@(r.Value.HasValue ? $"${r.Value.Value / 1e9:F2}B" : "—")</td>
        <td class="num-cell">@(r.Percentage.HasValue ? $"{r.Percentage.Value:F1}%" : "—")</td>
        <td style="text-align:right; white-space:nowrap;">
            <a asp-action="Edit" asp-route-id="@r.Id" class="btn-detail">EDIT</a>
            <form asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-detail" style="border:none; background:none; color:var(--red); cursor:pointer;">DEL</button>
            </form>
        </td>
    </tr>
}
