@using simple_bloomberg_terminal.Models.Entities
@model IEnumerable<TradeBloc>

@if (!Model.Any()) { <tr><td colspan="5" class="muted-cell" style="text-align:center; padding:1rem;">No results</td></tr> }
@foreach (var t in Model)
{
    <tr>
        <td class="code-cell">@t.Code</td>
        <td class="name-cell">@t.Name</td>
        <td class="tag-cell">@t.Countries.Count(c => c.DeletedAt == null)</td>
        <td class="num-cell">@(t.FoundedDate?.ToShortDateString() ?? "—")</td>
        <td style="text-align:right; white-space:nowrap;">
            <a asp-action="Edit" asp-route-id="@t.Id" class="btn-detail">EDIT</a>
            <form asp-action="Delete" asp-route-id="@t.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete @t.Name?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-detail" style="border:none; background:none; color:var(--red); cursor:pointer;">DEL</button>
            </form>
        </td>
    </tr>
}
