            <div id="costDiscoverResults" class="js-discover-results muted-cell" style="margin-top:.5rem;"></div>
            @if (!Model.CostSources.Any())
            {
                <div class="detail-pending">NO COST SOURCES ON RECORD</div>
            }
            else
            {
                <table class="terminal-table" id="costTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Cost base</th>
                            <th>Value</th>
                            <th>%</th>
                            <th>Source</th>
                            <th>Counterparty</th>
                            <th>Proof filing</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.CostSources)
                        {
                            @* A real segment to search by: not an EDGAR period-total, not itself a linked counterparty. *@
                            <tr data-segment="@(c.RelatedCompanyId == null && c.DataSource != DataSource.EDGAR ? c.Name : null)">
                                <td class="name-cell">@c.Name</td>
                                <td class="tag-cell">@c.CostBase</td>
                                <td class="num-cell">@(c.Value.HasValue ? "$" + (c.Value.Value / 1e9).ToString("F2") + "B" : "—")</td>
                                <td class="num-cell">@(c.Percentage.HasValue ? c.Percentage.Value.ToString("F1") + "%" : "—")</td>
                                <td class="tag-cell">@(c.DataSource?.ToString() ?? "—")</td>
                                <td class="name-cell">@(c.RelatedCompany != null && c.RelatedCompany.DeletedAt == null ? c.RelatedCompany.Name : "—")</td>
                                <td class="muted-cell">
