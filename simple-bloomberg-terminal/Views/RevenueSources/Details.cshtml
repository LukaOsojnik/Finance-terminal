@using simple_bloomberg_terminal.Models.Entities
@model simple_bloomberg_terminal.Models.ViewModels.RevenueSourceDetailViewModel
@{
    var src = Model.Source;
    ViewData["Title"] = (src.Company?.Name ?? "Revenue Source") + " — " + src.Name;
    // Inline edit form posts to Edit and returns here.
    ViewData["ReturnUrl"] = Context.Request.Path;
    ViewData["CancelUrl"] = Context.Request.Path;

    string Short(string? s, int n = 90)
    {
        s = (s ?? "").Replace("\n", " ").Trim();
        return s.Length > n ? s.Substring(0, n) + "…" : s;
    }
}

@* ── Hero ── *@
<section class="detail-hero">
    <div class="detail-hero-back">
        <a asp-controller="RevenueSources" asp-action="Index" class="detail-back-link">← REVENUE SOURCES</a>
    </div>
    <div class="detail-hero-top">
        <div class="detail-hero-name-row">
            <h1 class="detail-hero-name">@src.Name</h1>
            <span class="detail-code-badge">@src.SourceType</span>
            @if (src.Company != null)
            {
                <span class="detail-region-tag">@src.Company.Name</span>
            }
        </div>
        @if (src.DataSource.HasValue)
        {
            <div class="detail-hero-sub">SOURCE: <span class="detail-hero-accent">@src.DataSource.Value</span></div>
        }
    </div>
    <div class="detail-metrics-row">
        <div class="detail-metric-card">
            <div class="detail-metric-label">VALUE</div>
            <div class="detail-metric-value">@(src.Value.HasValue ? "$" + (src.Value.Value / 1e9).ToString("F2") + "B" : "—")</div>
        </div>
        <div class="detail-metric-card">
            <div class="detail-metric-label">SHARE OF REVENUE</div>
            <div class="detail-metric-value">@(src.Percentage.HasValue ? src.Percentage.Value.ToString("F1") + "%" : "—")</div>
        </div>
        <div class="detail-metric-card">
            <div class="detail-metric-label">PROOF FIELDS</div>
            <div class="detail-metric-value">@Model.Reviews.Count()</div>
        </div>
        <div class="detail-metric-card">
            <div class="detail-metric-label">COMPANY</div>
            <div class="detail-metric-value">@(src.Company?.Name ?? "—")</div>
        </div>
    </div>
</section>

@* ── Edit fields ── *@
<div class="detail-section-label">// EDIT FIELDS</div>
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="detail-card">
            @await Html.PartialAsync("_FieldsForm", Model.Edit)
        </div>
    </div>
</div>

@* ── Connected filings / proof (per field) ── *@
<div class="detail-section-label">// CONNECTED FILINGS — PROOF PER FIELD</div>
<div class="row g-3 mb-5">
    <div class="col-12">
        <div class="detail-card">
            <div class="mb-2">
                <a asp-controller="Extraction" asp-action="Index" asp-route-companyId="@src.CompanyId" asp-route-revenueSourceId="@src.Id" class="btn-detail">ADD REFERENCES →</a>
            </div>
            @if (!Model.Reviews.Any())
            {
                <div class="detail-pending">NO PROOF ON RECORD YET.</div>
            }
            else
            {
                <table class="terminal-table">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th>Proof snapshot</th>
                            <th>Filing</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rev in Model.Reviews)
                        {
                            <tr>
                                <td class="tag-cell">@rev.Field</td>
                                <td class="name-cell" title="@rev.ReferenceSnapshot">“@Short(rev.ReferenceSnapshot)”</td>
                                <td class="muted-cell">
                                    @if (rev.Filing != null && rev.Filing.DeletedAt == null)
                                    {
                                        <a href="@rev.Filing.PrimaryDocUrl" target="_blank" rel="noopener">@rev.Filing.Form @rev.Filing.AccessionNumber</a>
                                    }
                                    else
                                    {
                                        <span class="muted-cell">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
