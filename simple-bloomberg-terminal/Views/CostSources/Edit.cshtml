@model simple_bloomberg_terminal.Models.ViewModels.CostSourceEditModel
@{ ViewData["Title"] = "Edit Cost Source"; }

<div class="page-header"><h2><span class="page-header-accent">//</span> Edit Cost Source</h2></div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" style="max-width:640px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id"/>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="CompanyId" class="form-label">Company</label>
        @await Html.PartialAsync("_AutocompletePicker", new AutocompletePickerModel {
            FieldName = nameof(Model.CompanyId),
            SelectedId = Model.CompanyId,
            SelectedLabel = ViewBag.CompanyLabel as string ?? "",
            LookupUrl = Url.Action("Lookup", "Companies"),
            Required = true,
            Placeholder = "Type company name..."
        })
        <span asp-validation-for="CompanyId" class="text-danger"></span>
    </div>
    <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"/><span asp-validation-for="Name" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="CostBase" class="form-label"></label><select asp-for="CostBase" asp-items="ViewBag.CostBases" class="form-control"></select><span asp-validation-for="CostBase" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Value" class="form-label"></label><input asp-for="Value" class="form-control" type="number" step="any"/><span asp-validation-for="Value" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Percentage" class="form-label">% (0–100)</label><input asp-for="Percentage" class="form-control" type="number" step="0.1"/><span asp-validation-for="Percentage" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="DataSource" class="form-label"></label><select asp-for="DataSource" asp-items="ViewBag.DataSources" class="form-control"><option value="">— none —</option></select><span asp-validation-for="DataSource" class="text-danger"></span></div>
    <div class="mb-3">
        <label asp-for="RelatedCompanyId" class="form-label">Related Company</label>
        @await Html.PartialAsync("_AutocompletePicker", new AutocompletePickerModel {
            FieldName = nameof(Model.RelatedCompanyId),
            SelectedId = Model.RelatedCompanyId,
            SelectedLabel = ViewBag.RelatedCompanyLabel as string ?? "",
            LookupUrl = Url.Action("Lookup", "Companies"),
            Required = false,
            Placeholder = "Type company name (optional)..."
        })
        <span asp-validation-for="RelatedCompanyId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">SAVE</button>
    <a asp-action="Index" class="btn btn-secondary">CANCEL</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial"/> }
