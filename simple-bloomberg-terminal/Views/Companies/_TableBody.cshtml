@using simple_bloomberg_terminal.Models.Entities
@model IEnumerable<Company>

@if (!Model.Any())
{
    <tr><td colspan="7" class="muted-cell" style="text-align:center; padding:1rem;">No results</td></tr>
}
@foreach (var company in Model)
{
    <tr>
        <td class="name-cell" style="font-weight:500;">@company.Name</td>
        <td class="tag-cell">@(company.Country?.Name ?? "—")</td>
        <td class="tag-cell">@company.Sector</td>
        <td class="muted-cell" style="font-size:0.75rem;">@(company.Industry.HasValue ? company.Industry.Value.ToString().Replace("_", " ") : "—")</td>
        <td class="num-cell">@(company.RevenueTotal.HasValue ? $"${company.RevenueTotal.Value / 1e9:F0}B" : "—")</td>
        <td class="num-cell">
            @if (company.GrossMargin.HasValue)
            {
                var m = company.GrossMargin.Value;
                var mClass = m >= 0.5 ? "risk-low" : m >= 0.2 ? "risk-medium" : "risk-high";
                <span class="@mClass">@m.ToString("P1")</span>
            }
            else { <span class="muted-cell">—</span> }
        </td>
        <td style="text-align:right; white-space:nowrap;">
            <a asp-action="Details" asp-route-id="@company.Id" class="btn-detail">VIEW</a>
            <a asp-action="Edit" asp-route-id="@company.Id" class="btn-detail">EDIT</a>
            <form asp-route="CompanyDelete" asp-route-id="@company.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete @company.Name?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-detail" style="border:none; background:none; color:var(--red); cursor:pointer;">DEL</button>
            </form>
        </td>
    </tr>
}
