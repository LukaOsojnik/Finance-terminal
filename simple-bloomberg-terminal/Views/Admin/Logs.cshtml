@{
    ViewData["Title"] = "Server Logs";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">Server Logs</h2>
    <div class="d-flex gap-2 align-items-center">
        <select id="levelFilter" class="form-select form-select-sm" style="width:auto;">
            <option value="">All levels</option>
            <option value="ERR">Error</option>
            <option value="WRN">Warning</option>
            <option value="INF">Info</option>
            <option value="DBG">Debug</option>
        </select>
        <span id="statusBadge" class="type-badge" style="background:var(--bg-card);color:var(--muted);border:1px solid var(--border-subtle);">connecting…</span>
        <button id="pauseBtn" class="btn btn-sm btn-secondary">Pause</button>
        <button id="clearBtn" class="btn btn-sm btn-secondary">Clear</button>
    </div>
</div>

<div id="logContainer" style="
    background:var(--bg-surface);
    border:1px solid var(--border-subtle);
    border-radius:var(--radius-md);
    height:72vh;
    overflow-y:auto;
    padding:12px 16px;
    font-family:var(--font-mono);
    font-size:0.8rem;
    line-height:1.6;
">
    <div id="logLines"></div>
</div>

@section Scripts {
<script>
(function () {
    const container = document.getElementById('logContainer');
    const lines     = document.getElementById('logLines');
    const badge     = document.getElementById('statusBadge');
    const pauseBtn  = document.getElementById('pauseBtn');
    const clearBtn  = document.getElementById('clearBtn');
    const filter    = document.getElementById('levelFilter');

    let paused   = false;
    let es       = null;
    let buffer   = [];   // lines received while paused

    const LEVEL_COLORS = {
        'ERR': 'var(--red)',
        'FTL': 'var(--red)',
        'WRN': '#f0a830',
        'INF': 'var(--text-primary)',
        'DBG': 'var(--muted)',
        'TRC': 'var(--muted)',
    };

    function levelOf(text) {
        const m = text.match(/\[(ERR|FTL|WRN|INF|DBG|TRC)\]/);
        return m ? m[1] : 'INF';
    }

    function appendLine(text) {
        const lvl = levelOf(text);
        const activeFilter = filter.value;
        if (activeFilter && lvl !== activeFilter) return;

        const el = document.createElement('div');
        el.style.color = LEVEL_COLORS[lvl] || 'var(--text-primary)';
        el.style.whiteSpace = 'pre-wrap';
        el.style.wordBreak = 'break-all';
        el.textContent = text;
        lines.appendChild(el);

        // Keep at most 2000 lines in the DOM.
        while (lines.children.length > 2000) lines.removeChild(lines.firstChild);
    }

    function scrollBottom() {
        container.scrollTop = container.scrollHeight;
    }

    function flush() {
        const atBottom = container.scrollHeight - container.scrollTop - container.clientHeight < 40;
        buffer.forEach(appendLine);
        buffer = [];
        if (atBottom) scrollBottom();
    }

    function connect() {
        es = new EventSource('/Admin/LogStream');

        es.onopen = () => {
            badge.textContent = 'live';
            badge.style.color = 'var(--green)';
            badge.style.borderColor = 'var(--green)';
        };

        es.onmessage = (e) => {
            if (paused) { buffer.push(e.data); return; }
            const atBottom = container.scrollHeight - container.scrollTop - container.clientHeight < 40;
            appendLine(e.data);
            if (atBottom) scrollBottom();
        };

        es.onerror = () => {
            badge.textContent = 'disconnected';
            badge.style.color = 'var(--red)';
            badge.style.borderColor = 'var(--red)';
            es.close();
            setTimeout(connect, 3000);
        };
    }

    pauseBtn.addEventListener('click', () => {
        paused = !paused;
        pauseBtn.textContent = paused ? 'Resume' : 'Pause';
        if (!paused) { flush(); scrollBottom(); }
    });

    clearBtn.addEventListener('click', () => { lines.innerHTML = ''; buffer = []; });

    filter.addEventListener('change', () => { lines.innerHTML = ''; });

    connect();
    scrollBottom();
})();
</script>
}
