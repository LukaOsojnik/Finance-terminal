@using simple_bloomberg_terminal.Models.Entities
@model simple_bloomberg_terminal.Models.ViewModels.RevenueSourceDetailViewModel
@{
    var src = Model.Source;
    ViewData["Title"] = (src.Company?.Name ?? "Revenue Source") + " — " + src.Name;
    // Inline edit form posts to Edit and returns here.
    ViewData["ReturnUrl"] = Context.Request.Path;
    ViewData["CancelUrl"] = Context.Request.Path;

    string Short(string? s, int n = 90)
    {
        s = (s ?? "").Replace("\n", " ").Trim();
        return s.Length > n ? s.Substring(0, n) + "…" : s;
    }
}

@* ── Hero ── *@
<section class="detail-hero">
    <div class="detail-hero-back">
        <a asp-controller="RevenueSources" asp-action="Index" class="detail-back-link">← REVENUE SOURCES</a>
    </div>
    <div class="detail-hero-top">
        <div class="detail-hero-name-row">
            <h1 class="detail-hero-name">@src.Name</h1>
            <span class="detail-code-badge">@src.SourceType</span>
            @if (src.Company != null)
            {
                <span class="detail-region-tag">@src.Company.Name</span>
            }
        </div>
        @if (src.DataSource.HasValue)
        {
            <div class="detail-hero-sub">SOURCE: <span class="detail-hero-accent">@src.DataSource.Value</span></div>
        }
    </div>
    <div class="detail-metrics-row">
        <div class="detail-metric-card">
            <div class="detail-metric-label">VALUE</div>
            <div class="detail-metric-value">@(src.Value.HasValue ? "$" + (src.Value.Value / 1e9).ToString("F2") + "B" : "—")</div>
        </div>
        <div class="detail-metric-card">
            <div class="detail-metric-label">SHARE OF REVENUE</div>
            <div class="detail-metric-value">@(src.Percentage.HasValue ? src.Percentage.Value.ToString("F1") + "%" : "—")</div>
        </div>
        <div class="detail-metric-card">
            <div class="detail-metric-label">PROOF FIELDS</div>
            <div class="detail-metric-value">@Model.Reviews.Count()</div>
        </div>
        <div class="detail-metric-card">
            <div class="detail-metric-label">COMPANY</div>
            <div class="detail-metric-value">@(src.Company?.Name ?? "—")</div>
        </div>
    </div>
</section>

@* ── Edit fields ── *@
<div class="detail-section-label">// EDIT FIELDS</div>
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="detail-card">
            @await Html.PartialAsync("_FieldsForm", Model.Edit)
        </div>
    </div>
</div>

@* ── Connected filings / proof (per field) ── *@
<div class="detail-section-label">// CONNECTED FILINGS — PROOF PER FIELD</div>
<div class="row g-3 mb-5">
    <div class="col-12">
        <div class="detail-card">
            @if (!Model.Reviews.Any())
            {
                <div class="detail-pending">
                    NO PROOF ON RECORD —
                    <a asp-controller="Extraction" asp-action="Index" asp-route-companyId="@src.CompanyId" class="btn-detail">ADD REFERENCES →</a>
                </div>
            }
            else
            {
                <div class="mb-2">
                    <button type="button" id="loadEdgarBtn" class="btn btn-secondary" data-company="@src.CompanyId">BROWSE EDGAR FILINGS</button>
                    <span id="loadEdgarStatus" class="text-muted small"></span>
                </div>
                <table class="terminal-table">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th>Proof snapshot</th>
                            <th>Filing</th>
                            <th>Replace filing</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rev in Model.Reviews)
                        {
                            <tr>
                                <td class="tag-cell">@rev.Field</td>
                                <td class="name-cell" title="@rev.ReferenceSnapshot">“@Short(rev.ReferenceSnapshot)”</td>
                                <td class="muted-cell">
                                    @if (rev.Filing != null && rev.Filing.DeletedAt == null)
                                    {
                                        <a href="@rev.Filing.PrimaryDocUrl" target="_blank" rel="noopener">@rev.Filing.Form @rev.Filing.AccessionNumber</a>
                                    }
                                    else
                                    {
                                        <span class="muted-cell">—</span>
                                    }
                                </td>
                                <td>
                                    <form asp-action="SetReviewFiling" asp-route-id="@src.Id" asp-route-reviewId="@rev.Id" method="post" style="display:inline; white-space:nowrap;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="filingAccession" class="f-accession"/>
                                        <input type="hidden" name="filingForm" class="f-form"/>
                                        <input type="hidden" name="filingDate" class="f-date"/>
                                        <input type="hidden" name="filingUrl" class="f-url"/>
                                        <select class="form-control filing-picker" style="display:inline; width:auto; max-width:280px;">
                                            <option value="">— none —</option>
                                            @foreach (var f in Model.CompanyFilings)
                                            {
                                                <option value="@f.AccessionNumber"
                                                        data-form="@f.Form"
                                                        data-date="@(f.FilingDate?.ToString("yyyy-MM-dd"))"
                                                        data-url="@f.PrimaryDocUrl"
                                                        selected="@(rev.FilingId == f.Id)">@f.Form @f.AccessionNumber</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn-detail">SET</button>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="DetachReview" asp-route-id="@src.Id" asp-route-reviewId="@rev.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Detach this field\'s proof?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-detail">DETACH</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script>
    (function () {
        // Each picker's <select> is unnamed (display only); the chosen option's accession + metadata
        // are mirrored into the form's hidden inputs so SET posts an upsertable filing.
        function syncHidden(sel) {
            var form = sel.closest('form');
            var opt = sel.options[sel.selectedIndex];
            form.querySelector('.f-accession').value = opt.value || '';
            form.querySelector('.f-form').value = opt.dataset.form || '';
            form.querySelector('.f-date').value = opt.dataset.date || '';
            form.querySelector('.f-url').value = opt.dataset.url || '';
        }
        document.querySelectorAll('.filing-picker').forEach(function (sel) {
            syncHidden(sel);
            sel.addEventListener('change', function () { syncHidden(sel); });
        });

        // Browse the company's live EDGAR filings and add any new ones to every picker.
        var btn = document.getElementById('loadEdgarBtn');
        if (btn) btn.addEventListener('click', async function () {
            var status = document.getElementById('loadEdgarStatus');
            status.textContent = 'Loading EDGAR filings…';
            try {
                var res = await fetch('/api/stock/filings/' + btn.dataset.company);
                if (!res.ok) { status.textContent = 'Failed (' + res.status + '): ' + (await res.text()); return; }
                var filings = await res.json();
                document.querySelectorAll('.filing-picker').forEach(function (sel) {
                    var have = new Set(Array.from(sel.options).map(function (o) { return o.value; }));
                    filings.forEach(function (f) {
                        if (!f.accessionNumber || have.has(f.accessionNumber)) return;
                        var o = document.createElement('option');
                        o.value = f.accessionNumber;
                        o.textContent = (f.form || '') + ' ' + (f.filingDate || '') + ' (' + f.accessionNumber + ')';
                        o.dataset.form = f.form || '';
                        o.dataset.date = f.filingDate || '';
                        o.dataset.url = f.documentUrl || '';
                        sel.appendChild(o);
                    });
                });
                status.textContent = 'Loaded ' + filings.length + ' filings — pick one and SET.';
            } catch (e) { status.textContent = 'Network error: ' + e.message; }
        });
    })();
    </script>
}
