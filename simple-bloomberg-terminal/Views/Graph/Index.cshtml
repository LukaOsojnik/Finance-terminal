@model simple_bloomberg_terminal.Models.ViewModels.GraphIndexViewModel
@{
    ViewData["Title"] = "Graph Explorer";
}

<section class="graph-shell">
    <div class="graph-header">
        <h1 class="graph-title">GRAPH EXPLORER</h1>
        <div class="graph-controls">
            <label class="graph-label" for="graph-company-select">CENTER COMPANY</label>
            <select id="graph-company-select" class="graph-select">
                <option value="">— select —</option>
                @foreach (var co in Model.Companies)
                {
                    <option value="@co.Id" selected="@(Model.SelectedCompanyId == co.Id)">@co.Name</option>
                }
            </select>
            <label class="graph-check" title="Available when more than 5 customers have a value">
                <input type="checkbox" id="graph-filter-customers" disabled/>
                <span>TOP 5 CUSTOMERS</span>
            </label>
            <label class="graph-check" title="Available when a customer cites a filing">
                <input type="checkbox" id="graph-filter-customers-filings" disabled/>
                <span>CUSTOMERS W/ FILINGS</span>
            </label>
            <label class="graph-check" title="Available when more than 5 suppliers have a value">
                <input type="checkbox" id="graph-filter-suppliers" disabled/>
                <span>TOP 5 SUPPLIERS</span>
            </label>
            <label class="graph-check" title="Available when a supplier cites a filing">
                <input type="checkbox" id="graph-filter-suppliers-filings" disabled/>
                <span>SUPPLIERS W/ FILINGS</span>
            </label>
        </div>
    </div>

    <div class="graph-legend">
        <span class="legend-chip legend-center">CENTER</span>
        <span class="legend-chip legend-hub">CATEGORY HUB</span>
        <span class="legend-chip legend-revenue">REVENUE SRC</span>
        <span class="legend-chip legend-cost">COST SRC</span>
        <span class="legend-chip legend-event">EVENT</span>
        <span class="legend-chip legend-related">RELATED CO</span>
        <span class="legend-chip legend-filing">FILING</span>
    </div>

    <div id="graph-canvas" class="graph-canvas"></div>

    <aside id="graph-detail" class="graph-detail" hidden>
        <div class="graph-detail-head">
            <span id="graph-detail-group" class="graph-detail-group">—</span>
            <button type="button" class="graph-detail-close" onclick="document.getElementById('graph-detail').hidden=true">×</button>
        </div>
        <div id="graph-detail-label" class="graph-detail-label">—</div>
        <div id="graph-detail-meta" class="graph-detail-meta">—</div>
    </aside>
</section>

<style>
    .graph-shell { padding: 0.5rem 0 2rem; }
    .graph-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.75rem; gap: 1rem; flex-wrap: wrap; }
    .graph-title { font-family: var(--font-display); font-weight: 700; letter-spacing: 2px; color: var(--accent); margin: 0; font-size: 1.5rem; text-shadow: var(--accent-glow); }
    .graph-controls { display: flex; align-items: center; gap: 0.5rem; }
    .graph-label { font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 1.5px; color: var(--text-secondary); }
    .graph-select { background: var(--bg-surface); border: 1px solid var(--border-subtle); color: var(--text-primary); padding: 0.4rem 0.6rem; font-family: var(--font-mono); border-radius: var(--radius-sm); min-width: 220px; }
    .graph-select:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent-dim); }
    .graph-check { display: flex; align-items: center; gap: 0.35rem; font-family: var(--font-display); font-size: 0.72rem; letter-spacing: 1px; color: var(--text-secondary); cursor: pointer; user-select: none; }
    .graph-check input { accent-color: var(--accent); cursor: pointer; }
    .graph-check:has(input:disabled) { opacity: 0.4; cursor: not-allowed; }
    .graph-check:has(input:disabled) input { cursor: not-allowed; }
    .graph-check:has(input:checked) { color: var(--accent); }

    .graph-legend { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
    .legend-chip { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 1px; padding: 0.2rem 0.55rem; border-radius: 2px; border: 1px solid; }
    .legend-center  { color: #ffd166; border-color: #ffd16655; background: #ffd16615; }
    .legend-hub     { color: #cfd8dc; border-color: #cfd8dc55; background: #cfd8dc15; }
    .legend-revenue { color: var(--green); border-color: var(--green-dim); background: var(--green-dim); }
    .legend-cost    { color: var(--red); border-color: #f8514955; background: #f8514915; }
    .legend-event   { color: #c084fc; border-color: #c084fc55; background: #c084fc15; }
    .legend-related { color: var(--accent); border-color: var(--accent-dim); background: #00d4ff15; }
    .legend-filing  { color: #e0a458; border-color: #e0a45855; background: #e0a45815; }

    .graph-canvas { width: 100%; height: 72vh; min-height: 540px; background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); }

    .graph-detail { position: fixed; right: 1.5rem; top: 7rem; width: 320px; background: var(--bg-card); border: 1px solid var(--accent-dim); border-radius: var(--radius-md); padding: 0.9rem 1rem; box-shadow: var(--accent-glow); z-index: 50; }
    .graph-detail-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.4rem; }
    .graph-detail-group { font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 1.5px; color: var(--accent); text-transform: uppercase; }
    .graph-detail-close { background: transparent; border: none; color: var(--text-secondary); font-size: 1.4rem; cursor: pointer; line-height: 1; }
    .graph-detail-close:hover { color: var(--red); }
    .graph-detail-label { font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.3rem; }
    .graph-detail-meta { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-secondary); }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/vis-network@9.1.9/styles/vis-network.min.css"/>
    <script src="https://unpkg.com/vis-network@9.1.9/standalone/umd/vis-network.min.js"></script>

    <script>
        (function () {
            if (typeof vis === 'undefined') {
                console.error('vis-network failed to load from CDN');
                document.getElementById('graph-canvas').innerHTML =
                    '<div style="padding:1rem;color:#f85149;font-family:JetBrains Mono">vis-network library failed to load. Check network tab / CSP / ad-blockers.</div>';
                return;
            }
            const select = document.getElementById('graph-company-select');
            const custChk = document.getElementById('graph-filter-customers');
            const custFilingChk = document.getElementById('graph-filter-customers-filings');
            const supChk = document.getElementById('graph-filter-suppliers');
            const supFilingChk = document.getElementById('graph-filter-suppliers-filings');
            const canvas = document.getElementById('graph-canvas');
            const detail = document.getElementById('graph-detail');
            const detailGroup = document.getElementById('graph-detail-group');
            const detailLabel = document.getElementById('graph-detail-label');
            const detailMeta = document.getElementById('graph-detail-meta');

            const GROUP_STYLES = {
                center:       { color: { background: '#ffd16622', border: '#ffd166', highlight: { background: '#ffd16644', border: '#ffeaa0' } }, font: { color: '#ffd166', size: 18, face: 'Rajdhani' }, shape: 'box', borderWidth: 2 },
                'hub-revenue':{ color: { background: '#39d35333', border: '#39d353' }, font: { color: '#9ce8a8', face: 'Rajdhani', size: 15, bold: true }, shape: 'hexagon', size: 26, borderWidth: 3 },
                'hub-cost':   { color: { background: '#f8514933', border: '#f85149' }, font: { color: '#f5a8a3', face: 'Rajdhani', size: 15, bold: true }, shape: 'hexagon', size: 26, borderWidth: 3 },
                'hub-event':  { color: { background: '#c084fc33', border: '#c084fc' }, font: { color: '#d8b4fe', face: 'Rajdhani', size: 15, bold: true }, shape: 'hexagon', size: 26, borderWidth: 3 },
                'hub-related':{ color: { background: '#00d4ff33', border: '#00d4ff' }, font: { color: '#7ddff7', face: 'Rajdhani', size: 15, bold: true }, shape: 'hexagon', size: 26, borderWidth: 3 },
                revenue: { color: { background: '#39d35322', border: '#39d353' }, font: { color: '#9ce8a8', face: 'JetBrains Mono', size: 12 }, shape: 'dot', size: 14 },
                cost:    { color: { background: '#f8514922', border: '#f85149' }, font: { color: '#f5a8a3', face: 'JetBrains Mono', size: 12 }, shape: 'dot', size: 14 },
                event:   { color: { background: '#c084fc22', border: '#c084fc' }, font: { color: '#d8b4fe', face: 'JetBrains Mono', size: 12 }, shape: 'diamond', size: 14 },
                related: { color: { background: '#00d4ff22', border: '#00d4ff' }, font: { color: '#7ddff7', face: 'Rajdhani', size: 14 }, shape: 'ellipse', borderWidth: 2 },
                filing:  { color: { background: '#e0a45822', border: '#e0a458' }, font: { color: '#e8c89a', face: 'JetBrains Mono', size: 11 }, shape: 'square', size: 12 }
            };

            const EDGE_STYLES = {
                revenue: { color: { color: '#39d35366', highlight: '#39d353' }, dashes: false, length: 150 },
                cost:    { color: { color: '#f8514966', highlight: '#f85149' }, dashes: false, length: 150 },
                event:   { color: { color: '#c084fc66', highlight: '#c084fc' }, dashes: [4, 4], length: 150 },
                related: { color: { color: '#00d4ff88', highlight: '#00d4ff' }, dashes: false, width: 2, length: 150 },
                // filing edges are the outermost tier — give them a long rest length so a degree-1
                // filing is pushed past its source rather than drifting into the center↔source gap.
                filing:  { color: { color: '#e0a45866', highlight: '#e0a458' }, dashes: [2, 3], length: 260 }
            };

            let network = null;
            let lastData = null;
            let fullPayload = null;

            // The top-5 tick is usable only when a group has MORE than 5 leaves carrying a value
            // (below that it's a no-op); the with-filings tick only when a leaf cites a filing.
            function countWithValue(group) {
                return fullPayload.nodes.filter(n => n.group === group && n.valueUsd != null).length;
            }

            // Set of leaf ids that cite a filing — filing edges run leaf -> filing.
            function leavesWithFiling() {
                return new Set(fullPayload.edges.filter(e => e.group === 'filing').map(e => e.from));
            }

            function updateFilterAvailability() {
                const filingLeaves = fullPayload ? leavesWithFiling() : new Set();
                const hasFiling = group => fullPayload
                    && fullPayload.nodes.some(n => n.group === group && filingLeaves.has(n.id));

                const avail = [
                    [custChk, !!fullPayload && countWithValue('revenue') > 5],
                    [custFilingChk, hasFiling('revenue')],
                    [supChk, !!fullPayload && countWithValue('cost') > 5],
                    [supFilingChk, hasFiling('cost')]
                ];
                avail.forEach(([chk, ok]) => {
                    chk.disabled = !ok;
                    if (!ok) chk.checked = false;
                });
            }

            // Per side the kept leaves are the UNION of: top-5 by value (if its tick is on) and
            // every leaf citing a filing (if its tick is on). With neither tick on, the side is
            // untouched. Afterwards drop filing proof nodes left orphaned by removed leaves.
            // fullPayload stays intact so unticking restores everything without a refetch.
            function buildFiltered() {
                const removed = new Set();
                const filingLeaves = leavesWithFiling();

                function trim(group, top5On, filingsOn) {
                    if (!top5On && !filingsOn) return;
                    const keep = new Set();
                    if (top5On) {
                        fullPayload.nodes
                            .filter(n => n.group === group && n.valueUsd != null)
                            .sort((a, b) => b.valueUsd - a.valueUsd)
                            .slice(0, 5)
                            .forEach(n => keep.add(n.id));
                    }
                    if (filingsOn) {
                        fullPayload.nodes
                            .filter(n => n.group === group && filingLeaves.has(n.id))
                            .forEach(n => keep.add(n.id));
                    }
                    fullPayload.nodes
                        .filter(n => n.group === group && !keep.has(n.id))
                        .forEach(n => removed.add(n.id));
                }
                trim('revenue', custChk.checked, custFilingChk.checked);
                trim('cost', supChk.checked, supFilingChk.checked);

                // a filing survives only if some kept leaf still cites it
                const keptFilings = new Set(
                    fullPayload.edges
                        .filter(e => e.group === 'filing' && !removed.has(e.from))
                        .map(e => e.to));
                fullPayload.nodes
                    .filter(n => n.group === 'filing' && !keptFilings.has(n.id))
                    .forEach(n => removed.add(n.id));

                return {
                    centerId: fullPayload.centerId,
                    centerLabel: fullPayload.centerLabel,
                    nodes: fullPayload.nodes.filter(n => !removed.has(n.id)),
                    edges: fullPayload.edges.filter(e => !removed.has(e.from) && !removed.has(e.to))
                };
            }

            function applyFilters() {
                if (!fullPayload) return;
                render(buildFiltered());
            }

            function render(payload) {
                lastData = payload;
                const visNodes = payload.nodes.map(n => Object.assign({
                    id: n.id,
                    label: n.label,
                    title: n.title || '',
                    group: n.group,
                    _meta: n
                }, GROUP_STYLES[n.group] || {}));

                const visEdges = payload.edges.map(e => Object.assign({
                    from: e.from,
                    to: e.to,
                    label: e.label || '',
                    font: { color: '#7a9ab5', face: 'JetBrains Mono', size: 10, strokeWidth: 0, background: 'rgba(15,21,32,0.7)' },
                    smooth: { type: 'continuous' }
                }, EDGE_STYLES[e.group] || {}));

                if (network) network.destroy();
                network = new vis.Network(canvas, { nodes: visNodes, edges: visEdges }, {
                    physics: {
                        enabled: visEdges.length > 0,
                        barnesHut: { gravitationalConstant: -8000, springLength: 160, springConstant: 0.04, avoidOverlap: 0.2 },
                        stabilization: { iterations: 200 }
                    },
                    interaction: { hover: true, tooltipDelay: 120, navigationButtons: false, keyboard: false },
                    layout: { improvedLayout: true }
                });

                network.on('click', onNodeClick);
            }

            function onNodeClick(params) {
                if (!params.nodes || params.nodes.length === 0) {
                    detail.hidden = true;
                    return;
                }
                const id = params.nodes[0];
                const node = lastData.nodes.find(n => n.id === id);
                if (!node) return;

                let navTarget = null;
                if (node.group === 'related') {
                    navTarget = node.id.split(':')[1];
                } else if ((node.group === 'revenue' || node.group === 'cost') && node.relatedCompanyId) {
                    navTarget = String(node.relatedCompanyId);
                }
                if (navTarget) {
                    select.value = navTarget;
                    const url = new URL(window.location.href);
                    url.searchParams.set('companyId', navTarget);
                    history.replaceState({}, '', url);
                    detail.hidden = true;
                    load(navTarget);
                    return;
                }

                detailGroup.textContent = node.group.toUpperCase();
                detailLabel.textContent = node.label;
                detailMeta.textContent = node.title || (node.valueUsd ? `$${(node.valueUsd / 1e9).toFixed(2)}B` : '—');
                detail.hidden = false;
            }

            function load(companyId) {
                if (!companyId) { canvas.innerHTML = ''; fullPayload = null; updateFilterAvailability(); if (network) { network.destroy(); network = null; } return; }
                fetch(`/graph/data/company/${companyId}`, { headers: { 'Accept': 'application/json' } })
                    .then(r => r.ok ? r.json() : Promise.reject('HTTP ' + r.status))
                    .then(payload => {
                        console.log('graph payload', payload);
                        if (!payload.nodes || payload.nodes.length === 0) {
                            canvas.innerHTML = '<div style="padding:1rem;color:#f85149;font-family:JetBrains Mono">No graph data returned.</div>';
                            return;
                        }
                        fullPayload = payload;
                        updateFilterAvailability();
                        applyFilters();
                    })
                    .catch(err => {
                        console.error('graph fetch failed', err);
                        canvas.innerHTML = '<div style="padding:1rem;color:#f85149;font-family:JetBrains Mono">Fetch failed: ' + err + '</div>';
                    });
            }

            select.addEventListener('change', e => {
                const id = e.target.value;
                const url = new URL(window.location.href);
                if (id) url.searchParams.set('companyId', id); else url.searchParams.delete('companyId');
                history.replaceState({}, '', url);
                load(id);
            });

            [custChk, custFilingChk, supChk, supFilingChk]
                .forEach(chk => chk.addEventListener('change', applyFilters));

            const initial = select.value;
            if (initial) load(initial);
        })();
    </script>
}
