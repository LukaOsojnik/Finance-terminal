                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@* Extract-from-filings: pick one filing, fire a detached per-node scan job (bottom-right widget). *@
<div id="extractModal" class="extx-modal" hidden>
    <div class="extx-backdrop" data-extx-close></div>
    <div class="extx-panel">
        <div class="extx-head">
            <span class="extx-title">EXTRACT — <span id="extxNode"></span></span>
            <span id="extxCount" class="extx-count"></span>
            <input id="extxFilter" class="form-control extx-filter" placeholder="Filter form / date / description..."/>
            <button type="button" class="btn-detail" data-extx-close>✕ CLOSE</button>
        </div>
        <div id="extxGrid" class="extx-grid"></div>
        <div id="extxEmpty" class="extx-empty" hidden>No filings found.</div>
        <div class="extx-foot">
            <div id="extxStatus" class="muted-cell"></div>
            <button type="button" id="extxStart" class="btn-detail" disabled>START PROCESSING →</button>
        </div>
    </div>
</div>

<style>
    /* ── Extract-from-filings overlay ── */
    .extx-modal { position: fixed; inset: 0; z-index: 1050; display: flex; align-items: center; justify-content: center; }
    .extx-backdrop { position: absolute; inset: 0; background: rgba(4,8,13,.78); backdrop-filter: blur(2px); }
    .extx-panel {
        position: relative; width: 90vw; max-width: 1100px; height: 80vh; display: flex; flex-direction: column;
        background: var(--bg-surface); border: 1px solid var(--border-accent); border-radius: var(--radius-md);
        box-shadow: var(--accent-glow), 0 18px 60px rgba(0,0,0,.6); overflow: hidden;
    }
    .extx-head {
        display: flex; align-items: center; gap: 1rem; padding: .85rem 1.1rem;
        border-bottom: 1px solid var(--border-subtle); background: var(--bg-card);
    }
    .extx-title { font-family: var(--font-display); font-size: .85rem; font-weight: 700; letter-spacing: .14em;
        text-transform: uppercase; color: var(--text-primary); flex-shrink: 0; }
    .extx-count { font-family: var(--font-mono); font-size: .72rem; color: var(--accent); flex-shrink: 0; }
    .extx-filter { flex: 1; max-width: 360px; font-family: var(--font-mono); font-size: .78rem;
        background: var(--bg-base); color: var(--text-primary);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: .35rem .6rem; }
    .extx-head [data-extx-close] { margin-left: auto; }
    .extx-grid { flex: 1; overflow-y: auto; padding: 1.1rem; display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: .75rem; align-content: start; }
    .extx-card { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm);
        padding: .7rem .85rem; cursor: pointer; text-align: left; display: flex; flex-direction: column; gap: .4rem;
        transition: border-color var(--transition), box-shadow var(--transition); }
    .extx-card:hover { border-color: var(--accent-dim); box-shadow: var(--accent-glow); }
    .extx-card.sel { border-color: var(--accent); box-shadow: var(--accent-glow); background: #00d4ff14; }
    .extx-card.no-doc { opacity: .45; cursor: not-allowed; }
    .extx-card-top { display: flex; align-items: center; justify-content: space-between; gap: .5rem; }
    .extx-form { font-family: var(--font-display); font-weight: 700; font-size: .72rem; letter-spacing: .1em;
        color: var(--accent); background: #00d4ff12; border: 1px solid var(--border-accent); padding: .12rem .5rem; border-radius: var(--radius-sm); }
    .extx-date { font-family: var(--font-mono); font-size: .72rem; color: var(--text-secondary); }
    .extx-desc { font-family: var(--font-mono); font-size: .73rem; color: var(--muted); line-height: 1.4;
        overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    .extx-empty { padding: 2rem; text-align: center; font-family: var(--font-mono); font-size: .8rem; color: var(--muted); }
    .extx-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: .75rem 1.1rem; border-top: 1px solid var(--border-subtle); background: var(--bg-card); }

    /* Rotating glyph for an in-flight discovery search row (the ⟳ while a query is live). */
    @@keyframes disc-spin { to { transform: rotate(360deg); } }
    .disc-spin { display: inline-block; animation: disc-spin .8s linear infinite; }

    /* Collapsible query rows: hide the native disclosure triangle, use our own chevron that rotates
       to point up when the row is expanded (like a citations expander). */
    .disc-row > summary { list-style: none; }
    .disc-row > summary::-webkit-details-marker { display: none; }
    .disc-chev { transition: transform .15s ease; opacity: .7; }
    .disc-row[open] > summary .disc-chev { transform: rotate(180deg); }
</style>

@section Scripts {
<script>
// RE-DISCOVER (private companies): fire the detached re-discovery, hand the job id to the bottom-right
// widget, and let the page reload itself when the widget sees the job finish (see site.js poll()).
document.querySelectorAll('.js-rediscover').forEach(btn => {
    const original = btn.textContent;
    btn.addEventListener('click', async () => {
        if (window.uiConfirm && !(await uiConfirm(btn.dataset.confirm, { danger: true }))) return;
        btn.disabled = true;
        btn.textContent = 'STARTING…';
        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const res = await fetch(`/companies/${btn.dataset.company}/rediscover`, {
                method: 'POST', headers: { 'RequestVerificationToken': token }
            });
            if (!res.ok) { btn.textContent = 'FAILED — ' + (await res.text() || res.status); btn.disabled = false; return; }
            const { jobId } = await res.json();
            if (window.startScanJob) window.startScanJob(jobId, {
                kind: 'rediscover', companyId: Number(btn.dataset.company), companyName: btn.dataset.name,
                filingLabel: 'Profile re-discovery', node: 'PROFILE', progress: 'Searching the web with sonar-pro…'
            });
            // The widget now owns progress + the accept/reject verdict — restore the button so it's not
            // stuck on a stale "running" label and can be fired again.
            btn.textContent = original;
            btn.disabled = false;
        } catch (e) { btn.textContent = 'FAILED — ' + e.message; btn.disabled = false; }
    });
});

// Financial-history annual/quarterly toggle: show the matching panel, mark the button active.
function bindFinTabs() {
    document.querySelectorAll('[data-fin-tab]').forEach(btn => {
        btn.addEventListener('click', () => {
            const tab = btn.dataset.finTab;
            document.querySelectorAll('[data-fin-tab]').forEach(b => b.classList.toggle('active', b === btn));
            document.querySelectorAll('[data-fin-panel]').forEach(p => {
                p.style.display = p.dataset.finPanel === tab ? '' : 'none';
            });
        });
    });
}
bindFinTabs();

// Re-discovery finished -> pull the fresh Details HTML and swap just the value regions in place, so the
// page doesn't fully reload (scroll/widget stay put). The bottom-right widget calls this on completion.
// Re-binds the fin-history tabs since replacing that region's HTML drops their listeners.
window.refreshCompanyProfile = async function (companyId) {
    try {
        const res = await fetch(`/companies/${companyId}/profile`);
        if (!res.ok) return;
        const doc = new DOMParser().parseFromString(await res.text(), 'text/html');
        for (const id of ['cvHeroSub', 'cvHeroMetrics', 'cvCompanyData', 'cvFinHistory']) {
            const fresh = doc.getElementById(id), cur = document.getElementById(id);
            if (fresh && cur) cur.innerHTML = fresh.innerHTML;
        }
        bindFinTabs();
    } catch { /* leave the page as-is on a fetch error */ }
};
(function () {
    // One handler for both section buttons: collect the section's segment names from its table, ask
    // sonar for the named counterparties per segment, render grouped, and link on confirm.
    document.querySelectorAll('.js-discover').forEach(btn => {
        btn.addEventListener('click', () => run(btn));
    });

    async function run(btn) {
        const companyId = Number(btn.dataset.company);
        const side = btn.dataset.side;                 // CUSTOMER (revenue) | SUPPLIER (cost)
        const valued = btn.dataset.valued === 'true';  // true => biggest counterparties + contract value
        const table = document.getElementById(btn.dataset.table);
        const out = document.getElementById(btn.dataset.results);

        const segments = table
            ? [...table.querySelectorAll('tr[data-segment]')].map(tr => tr.dataset.segment).filter(Boolean)
            : [];

        btn.disabled = true;
        const label = btn.textContent;

        // Live feed (top) + grouped results (below), both filled as the NDJSON stream arrives — the
        // planner emits its sub-queries first, then a searching/result pair per query (Perplexity-style).
        out.innerHTML = '';
        const feed = document.createElement('div');
        feed.style.cssText = 'margin:.25rem 0 .5rem;';
        const results = document.createElement('div');
        out.append(feed, results);

        const status = document.createElement('div');
        status.className = 'muted-cell';
        const noun = side === 'SUPPLIER' ? 'suppliers' : 'customers';
        status.textContent = `Planning searches for ${valued ? 'biggest ' + noun + ' (with contract value)' : noun}…`;
        feed.appendChild(status);

        const feedRows = new Map();   // query -> its <details> feed row
        const groups = new Map();     // segment -> tbody (append-only, so LINK state survives new results)
        let found = 0;

        try {
            const resp = await fetch('/extraction/discover-related', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ companyId, side, segments, valued })
            });
            if (!resp.ok || !resp.body) { status.textContent = `Discovery failed (${resp.status}). Check the Perplexity API key.`; return; }

            // Read NDJSON line by line (same pattern as the filing chat stream).
            const reader = resp.body.getReader(), dec = new TextDecoder();
            let buf = '';
            while (true) {
                const { value, done } = await reader.read();
                if (done) break;
                buf += dec.decode(value, { stream: true });
                let nl;
                while ((nl = buf.indexOf('\n')) >= 0) {
                    const line = buf.slice(0, nl).trim(); buf = buf.slice(nl + 1);
                    if (!line) continue;
                    let ev; try { ev = JSON.parse(line); } catch { continue; }

                    if (ev.t === 'plan') {
                        status.textContent = `${ev.queries.length} search${ev.queries.length === 1 ? '' : 'es'} planned`;
                        for (const q of ev.queries) feedRows.set(q, addFeedRow(feed, q));
                    } else if (ev.t === 'searching') {
                        setFeed(feedRows.get(ev.query), '⟳', 'searching…', true);
                    } else if (ev.t === 'result') {
                        const items = ev.items || [], sources = ev.sources || [];
                        found += items.length;
                        const row = feedRows.get(ev.query);
                        if (ev.error) setFeed(row, '✕', ev.error, false);
                        else setFeed(row, '✓', `${items.length} found · ${sources.length} source${sources.length === 1 ? '' : 's'}`, false);
                        setRowSources(row, sources);   // tuck this query's fetched links inside it (collapsed)
                        for (const s of items) appendResult(results, groups, s, companyId);
                    } else if (ev.t === 'error') {
                        status.textContent = `[${ev.c}]`;
                    }
                }
            }
            status.textContent = found === 0
                ? 'No named counterparties found.'
                : `Done — ${found} counterpart${found === 1 ? 'y' : 'ies'} across ${feedRows.size} search${feedRows.size === 1 ? '' : 'es'}.`;
        } catch {
            status.textContent = 'Discovery failed — network error.';
        } finally {
            btn.disabled = false;
            btn.textContent = label;
        }
    }

    // One live-feed row as a collapsible <details>: the summary shows glyph + query + tail status; the
    // body (hidden until clicked) holds the links that query fetched. Collapsed by default to stay compact.
    function addFeedRow(feed, query) {
        const row = document.createElement('details');
        row.className = 'disc-row';
        row.style.cssText = 'padding:.1rem 0;';
        const summary = document.createElement('summary');
        summary.style.cssText = 'display:flex;gap:.5rem;align-items:baseline;cursor:pointer;';
        summary.innerHTML =
            `<span class="js-glyph" style="width:1rem;flex:none;">·</span>` +
            `<span style="flex:1;">${esc(query)}</span>` +
            `<span class="js-tail muted-cell" style="flex:none;">queued</span>` +
            `<span class="disc-chev" style="flex:none;">▾</span>`;
        const body = document.createElement('div');
        body.className = 'js-srcs';
        body.style.cssText = 'margin:.25rem 0 .5rem 1.5rem;';
        row.append(summary, body);
        feed.appendChild(row);
        return row;
    }

    // spin=true while the query is in flight → the glyph rotates so the user sees it's live.
    function setFeed(row, glyph, tail, spin) {
        if (!row) return;
        const g = row.querySelector('.js-glyph');
        g.textContent = glyph;
        g.classList.toggle('disc-spin', !!spin);
        row.querySelector('.js-tail').textContent = tail;
    }

    // Fill a query row's collapsed body with the source links it fetched (one line each: host + URL).
    function setRowSources(row, urls) {
        if (!row) return;
        const body = row.querySelector('.js-srcs');
        if (!urls.length) { body.innerHTML = `<span class="muted-cell">no sources</span>`; return; }
        const list = document.createElement('ul');
        list.style.cssText = 'margin:0;padding:0 0 0 1rem;list-style:disc;';
        for (const url of urls) {
            let host = url; try { host = new URL(url).hostname.replace(/^www\./, ''); } catch {}
            const li = document.createElement('li');
            li.innerHTML = `<a href="${url}" target="_blank" rel="noopener">${esc(host)}</a> <span class="muted-cell">${esc(url)}</span>`;
            list.appendChild(li);
        }
        body.innerHTML = '';
        body.appendChild(list);
    }

    // Append one suggestion under its segment, creating the segment's table on first sight. Append-only
    // so any LINK buttons the user already clicked keep their state as more results stream in.
    function appendResult(results, groups, s, companyId) {
        const key = s.segment || '(unspecified)';
        let tbody = groups.get(key);
        if (!tbody) {
            const heading = document.createElement('div');
            heading.className = 'detail-section-label';
            heading.style.marginTop = '1rem';
            heading.textContent = `› ${key}`;
            results.appendChild(heading);

            const table = document.createElement('table');
            table.className = 'terminal-table';
            table.innerHTML = `<thead><tr><th>Company</th><th>Class</th><th>Value</th><th>Note</th><th>Source</th><th></th></tr></thead>`;
            tbody = document.createElement('tbody');
            table.appendChild(tbody);
            results.appendChild(table);
            groups.set(key, tbody);
        }

        const tr = document.createElement('tr');
        const src = s.sourceUrl ? `<a href="${s.sourceUrl}" target="_blank" rel="noopener">link</a>` : '<span class="muted-cell">—</span>';
        const known = s.existingCompanyId ? ' <span class="tag-cell">(known)</span>' : '';
        tr.innerHTML =
            `<td class="name-cell">${esc(s.name)}${known}</td>` +
            `<td class="tag-cell">${esc(s.classification)}</td>` +
            `<td class="num-cell">${fmtVal(s.contractValue)}</td>` +
            `<td class="muted-cell">${esc(s.note || '—')}</td>` +
            `<td class="muted-cell">${src}</td>`;
        const action = document.createElement('td');
        const link = document.createElement('button');
        link.type = 'button';
        link.className = 'btn-detail';
        link.textContent = s.side === 'SUPPLIER' ? 'LINK SUPPLIER' : 'LINK CUSTOMER';
        link.addEventListener('click', () => linkOne(s, link, companyId));
        action.appendChild(link);
        tr.appendChild(action);
        tbody.appendChild(tr);
    }

    async function linkOne(s, btnEl, companyId) {
        btnEl.disabled = true;
        btnEl.textContent = 'LINKING…';
        try {
            const resp = await fetch('/extraction/link-counterparty', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    companyId,
                    name: s.name,
                    side: s.side,
                    classification: s.classification,
                    existingCompanyId: s.existingCompanyId ?? null,
                    countryCode: s.countryCode ?? null,
                    sector: s.sector ?? null,
                    ticker: s.ticker ?? null,
                    sourceUrl: s.sourceUrl ?? null,
                    note: s.note ?? null,
                    value: s.contractValue ?? null
                })
            });
            if (!resp.ok) { btnEl.textContent = 'FAILED'; btnEl.disabled = false; return; }
            btnEl.textContent = 'LINKED ✓';
        } catch {
            btnEl.textContent = 'FAILED';
            btnEl.disabled = false;
        }
    }

    function esc(v) {
        return String(v).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    // Format a raw USD contract value into a compact $X.XB / $XXXM / $XXXk (matches the main tables'
    // billions convention). Only the valued mode populates this; plain mode rows show "—".
    function fmtVal(v) {
        if (v == null || isNaN(v)) return '—';
        if (v >= 1e9) return '$' + (v / 1e9).toFixed(2) + 'B';
        if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
        if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'k';
        return '$' + v.toFixed(0);
    }

    // ── Extract from filings ──────────────────────────────────────────────────────────────────
    // Each section's button opens this single popup pinned to that section's node (REVENUE / COST /
    // RISK). Pick one filing, hit START PROCESSING: that fires the SAME detached scan the Extraction
    // page's Auto-Scan does (POST /extraction/scan-auto-async), then hands the job to the bottom-right
    // widget via window.startScanJob so the user keeps browsing while it runs.
    const COMPANY_NAME = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(co.Name));
    const extModal = document.getElementById('extractModal');
    const extGrid = document.getElementById('extxGrid');
    const extFilter = document.getElementById('extxFilter');
    const extStart = document.getElementById('extxStart');
    const extStatus = document.getElementById('extxStatus');
    let extAll = [];           // filings fetched for the open company
    let extSel = null;         // the one filing the user selected
    let extNode = 'REVENUE';   // node this run extracts (set by the clicked button)
    let extCompany = 0;

    function closeExt() { extModal.hidden = true; }

    function openExt(companyId, node) {
        extCompany = companyId; extNode = node; extSel = null; extAll = [];
        document.getElementById('extxNode').textContent = node;
        extFilter.value = ''; extStart.disabled = true; extStatus.textContent = '';
        document.getElementById('extxCount').textContent = 'loading…';
        extGrid.innerHTML = ''; document.getElementById('extxEmpty').hidden = true;
        extModal.hidden = false;
        fetch(`/api/stock/filings/${companyId}`)
            .then(r => r.ok ? r.json() : Promise.reject(r.status))
            .then(list => { extAll = list; renderExt(list); })
            .catch(s => { document.getElementById('extxCount').textContent = `failed (${s})`; });
    }

    function renderExt(list) {
        extGrid.innerHTML = '';
        list.forEach(f => {
            const hasDoc = !!(f.accessionNumber && f.primaryDocument);
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'extx-card' + (hasDoc ? '' : ' no-doc');
            card.innerHTML =
                `<div class="extx-card-top"><span class="extx-form">${esc(f.form || '—')}</span>` +
                `<span class="extx-date">${esc(f.filingDate || '')}</span></div>` +
                (f.description ? `<div class="extx-desc">${esc(f.description)}</div>` : '');
            if (hasDoc) card.addEventListener('click', () => {
                extGrid.querySelectorAll('.extx-card').forEach(c => c.classList.remove('sel'));
                card.classList.add('sel');
                extSel = f; extStart.disabled = false;
            });
            extGrid.appendChild(card);
        });
        document.getElementById('extxCount').textContent = `${list.length} shown`;
        document.getElementById('extxEmpty').hidden = list.length > 0;
    }

    extFilter.addEventListener('input', () => {
        const q = extFilter.value.trim().toLowerCase();
        renderExt(!q ? extAll : extAll.filter(f =>
            `${f.form || ''} ${f.filingDate || ''} ${f.description || ''}`.toLowerCase().includes(q)));
    });

    extStart.addEventListener('click', async () => {
        if (!extSel) return;
        extStart.disabled = true;
        extStatus.textContent = 'Starting scan…';
        const filingLabel = `${extSel.form || 'filing'} ${extSel.filingDate || ''}`.trim();
        const qs = `accession=${encodeURIComponent(extSel.accessionNumber)}&doc=${encodeURIComponent(extSel.primaryDocument)}` +
            `&node=${extNode}&form=${encodeURIComponent(extSel.form || '')}` +
            `&companyName=${encodeURIComponent(COMPANY_NAME)}&filingLabel=${encodeURIComponent(filingLabel)}`;
        try {
            const res = await fetch(`/extraction/scan-auto-async/${extCompany}?${qs}`, { method: 'POST' });
            if (!res.ok) { extStatus.textContent = 'Scan failed: ' + await res.text(); extStart.disabled = false; return; }
            const r = await res.json();
            if (window.startScanJob) window.startScanJob(r.jobId, {
                companyId: extCompany, companyName: COMPANY_NAME, filingLabel, node: extNode,
                accession: extSel.accessionNumber, doc: extSel.primaryDocument,
                form: extSel.form || null, progress: 'Starting…'
            });
            closeExt();
        } catch (e) { extStatus.textContent = 'Network error: ' + e.message; extStart.disabled = false; }
    });

    extModal.querySelectorAll('[data-extx-close]').forEach(el => el.addEventListener('click', closeExt));
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !extModal.hidden) closeExt(); });
    document.querySelectorAll('.js-extract-filings').forEach(btn =>
        btn.addEventListener('click', () => openExt(Number(btn.dataset.company), btn.dataset.node)));
})();
</script>
}
