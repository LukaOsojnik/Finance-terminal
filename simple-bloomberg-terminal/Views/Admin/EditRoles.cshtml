@model simple_bloomberg_terminal.Models.ViewModels.EditRolesViewModel
@{
    ViewData["Title"] = "Edit roles";
}

<h2>Roles for @Model.Email</h2>

<form asp-action="EditRoles" method="post" style="max-width:360px;">
    <input type="hidden" asp-for="UserId"/>
    <input type="hidden" asp-for="Email"/>

    @for (var i = 0; i < Model.Roles.Count; i++)
    {
        <input type="hidden" asp-for="Roles[i].Name"/>
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="Roles[i].Selected"/>
            <label class="form-check-label" asp-for="Roles[i].Selected">@Model.Roles[i].Name</label>
        </div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
