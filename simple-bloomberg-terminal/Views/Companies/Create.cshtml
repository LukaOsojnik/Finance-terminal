@model simple_bloomberg_terminal.Models.ViewModels.CompanyCreateModel
@{
    ViewData["Title"] = "New Company";
    var fetched = ViewBag.Fetched == true;
}

<div class="page-header"><h2><span class="page-header-accent">//</span> New Company</h2></div>

<div class="company-form">
    <form asp-action="Fetch" method="post" class="fetch-bar">
        @Html.AntiForgeryToken()
        <label class="fetch-bar-label" for="symbol">Fetch from API</label>
        <input id="symbol" name="symbol" class="form-control" placeholder="Ticker — e.g. RL" autofocus/>
        <button type="submit" class="btn btn-secondary">FETCH</button>
    </form>

    @if (fetched)
    {
        <div class="fetch-banner"><span class="dot"></span>Prefilled from FMP / Yahoo — review the highlighted fields and save.</div>
    }
    @if (ViewBag.FetchNote != null)
    {
        <div class="alert alert-warning">@ViewBag.FetchNote</div>
    }

    <form asp-route="CompaniesCreate" method="post" class="@(fetched ? "was-fetched" : null)">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-cards">
            <div class="form-card">
                <div class="form-card-title">Identity</div>
                <div class="form-stack">
                    <div class="@(string.IsNullOrEmpty(Model.Name) ? null : "field-glow")">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control"/>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="@(string.IsNullOrEmpty(Model.Cik) ? null : "field-glow")">
                        <label asp-for="Cik" class="form-label"></label>
                        <input asp-for="Cik" class="form-control"/>
                        <span asp-validation-for="Cik" class="text-danger"></span>
                    </div>
                    <div class="@(Model.CountryId == 0 ? null : "field-glow")">
                        <label asp-for="CountryId" class="form-label">Country</label>
                        @await Html.PartialAsync("_AutocompletePicker", new AutocompletePickerModel {
                            FieldName = nameof(Model.CountryId),
                            SelectedId = Model.CountryId == 0 ? null : Model.CountryId,
                            SelectedLabel = ViewBag.CountryLabel as string ?? "",
                            LookupUrl = Url.Action("Lookup", "Countries"),
                            Required = true,
                            Placeholder = "Type country name..."
                        })
                        <span asp-validation-for="CountryId" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-title">Classification</div>
                <div class="form-stack">
                    <div class="@(fetched ? "field-glow" : null)">
                        <label asp-for="Sector" class="form-label"></label>
                        <select asp-for="Sector" asp-items="ViewBag.Sectors" class="form-control"></select>
                        <span asp-validation-for="Sector" class="text-danger"></span>
                    </div>
                    <div class="@(Model.Industry.HasValue ? "field-glow" : null)">
                        <label asp-for="Industry" class="form-label"></label>
                        <select asp-for="Industry" asp-items="ViewBag.Industries" class="form-control"><option value="">— none —</option></select>
                        <span asp-validation-for="Industry" class="text-danger"></span>
                    </div>
                    <div class="@(Model.AsOf.HasValue ? "field-glow" : null)">
                        <label asp-for="AsOf" class="form-label"></label>
                        <partial name="_DateTimePicker" model="@(new DateTimePickerModel {
                            FieldName = "AsOf",
                            IsoValue = Model.AsOf?.ToString("yyyy-MM-dd") ?? "",
                            FormattedValue = Model.AsOf?.ToString("d") ?? ""
                        })"/>
                        <span asp-validation-for="AsOf" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-card card-span">
                <div class="form-card-title">Financials</div>
                <div class="form-grid">
                    <div class="@(Model.RevenueTotal.HasValue ? "field-glow" : null)">
                        <label asp-for="RevenueTotal" class="form-label"></label>
                        <input asp-for="RevenueTotal" class="form-control" type="number" step="any"/>
                        <span asp-validation-for="RevenueTotal" class="text-danger"></span>
                    </div>
                    <div class="@(Model.GrossMargin.HasValue ? "field-glow" : null)">
                        <label asp-for="GrossMargin" class="form-label">Gross Margin (0–1)</label>
                        <input asp-for="GrossMargin" class="form-control" type="number" step="0.01"/>
                        <span asp-validation-for="GrossMargin" class="text-danger"></span>
                    </div>
                    <div class="field-full @(string.IsNullOrEmpty(Model.Notes) ? null : "field-glow")">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">CREATE</button>
            <a asp-action="Index" class="btn btn-secondary">CANCEL</a>
            @if (fetched)
            {
                <span class="form-actions-hint">Data prefilled — adjust anything, then create.</span>
            }
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial"/> }
