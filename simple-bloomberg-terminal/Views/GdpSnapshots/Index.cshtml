@using simple_bloomberg_terminal.Models.Entities
@model IEnumerable<GdpSnapshot>
@{ ViewData["Title"] = "GDP Snapshots"; }

<div class="page-header"><h2><span class="page-header-accent">//</span> GDP Snapshots</h2></div>

@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="d-flex" style="margin-bottom:1rem; gap:0.75rem; align-items:center;">
    <input type="text" class="form-control search-input" placeholder="Search country / year..." data-search-url="@Url.Action("Search")" style="max-width:420px;"/>
    <a asp-route="GdpSnapshotsCreate" class="btn btn-primary">+ NEW</a>
</div>

<table class="terminal-table">
    <thead><tr><th>Country</th><th>Year</th><th style="text-align:right;">GDP (USD)</th><th></th></tr></thead>
    <tbody id="table-body">@await Html.PartialAsync("_TableBody", Model)</tbody>
</table>
