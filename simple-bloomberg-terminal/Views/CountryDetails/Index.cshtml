@using simple_bloomberg_terminal.Models.Entities
@model IEnumerable<CountryDetails>
@{ ViewData["Title"] = "Country Details"; }

<div class="page-header"><h2><span class="page-header-accent">//</span> Country Details</h2></div>

@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="d-flex" style="margin-bottom:1rem; gap:0.75rem; align-items:center;">
    <input type="text" class="form-control search-input" placeholder="Search country / position..." data-search-url="@Url.Action("Search")" style="max-width:420px;"/>
    <a asp-action="Create" class="btn btn-primary">+ NEW</a>
</div>

<table class="terminal-table">
    <thead><tr><th>Country</th><th>Market Position</th><th></th></tr></thead>
    <tbody id="table-body">@await Html.PartialAsync("_TableBody", Model)</tbody>
</table>
