@using simple_bloomberg_terminal.Models.Entities
@model IEnumerable<CountryAdvantage>

@if (!Model.Any()) { <tr><td colspan="3" class="muted-cell" style="text-align:center; padding:1rem;">No results</td></tr> }
@foreach (var a in Model)
{
    <tr>
        <td class="name-cell">@(a.Country?.Name ?? a.CountryId.ToString())</td>
        <td class="tag-cell">@a.Text</td>
        <td style="text-align:right; white-space:nowrap;">
            <a asp-action="Edit" asp-route-id="@a.Id" class="btn-detail">EDIT</a>
            <form asp-action="Delete" asp-route-id="@a.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-detail" style="border:none; background:none; color:var(--red); cursor:pointer;">DEL</button>
            </form>
        </td>
    </tr>
}
